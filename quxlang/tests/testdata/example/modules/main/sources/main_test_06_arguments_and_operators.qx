::class_default_copy_class CLASS
{
  .x VAR I32;
}

::class_default_copy_assignment_test STATIC_TEST
{

    VAR a class_default_copy_class;
    a.x := 5;

    VAR b class_default_copy_class; // := a;
    b := a;

    ASSERT(b.x == 5);
}


::named_argument_passing_test STATIC_TEST
{
  VAR b bam;
  b.x := 5;
  VAR i I32;
  b.y := i<-;

  argument_passing_helper(@int i, @arg b);

  ASSERT(i == 6);
}


::named_argument_reordered_passing_test STATIC_TEST
{
  VAR b bam;
  b.x := 5;
  VAR i I32;
  b.y := i<-;

  argument_passing_helper(@arg b, @int i);

  ASSERT(i == 6);
}

::compound_assignment_operators_test STATIC_TEST
{
   VAR a I32 := 10;
   a += 5;
   ASSERT(a == 15);
   a -= 3;
   ASSERT(a == 12);
   a *= 2;
   ASSERT(a == 24);
   a /= 4;
   ASSERT(a == 6);
   a %= 4;
   ASSERT(a == 2);

   VAR b BYTE := 6;
   b #&&= 3;
   ASSERT(b == 2);
   b := 6;
   b #||= 3;
   ASSERT(b == 7);
   b := 6;
   b #^^= 3;
   ASSERT(b == 5);
   b := 6;
   b #&!= 3;
   ASSERT(b == 253);
   b := 6;
   b #|!= 3;
   ASSERT(b == 248);
   b := 6;
   b #^!= 3;
   ASSERT(b == 250);
   b := 6;
   b #^>= 3;
   ASSERT(b == 251);
   b := 6;
   b #^<= 3;
   ASSERT(b == 254);

   b := 1;
   b #++= 3;
   ASSERT(b == 8);
   b #--= 1;
   ASSERT(b == 4);
   b := 129;
   b #+%= 1;
   ASSERT(b == 3);
   b #-%= 1;
   ASSERT(b == 129);
}


::bitwise_operators_test STATIC_TEST
{
   // Shifts for I32 (uintptr shift amount)
   VAR a I32 := 5; // = 2^0 + 2^2 ->  2^1 + 2^3
   a := a #++ 1;
   ASSERT(a == 10);

   a := 4;
   a := a #-- 1;
   ASSERT(a == 2);

   a := a #++ 2; // 2^1 -> 2^3
   ASSERT(a == 8);

   a := 128;
   a := a #++ 1;
   ASSERT(a == 256);
   a := a #++ 1;
   ASSERT(a == 512);

   // Binary bitwise ops for I32
   VAR x I32 := 6; // 110b
   VAR y I32 := 3; // 011b
   ASSERT((x #&& y) == 2);
   ASSERT((x #|| y) == 7);
   ASSERT((x #^^ y) == 5);
   ASSERT((x #^> y) == 4294967291);
   ASSERT((x #^< y) == 4294967294);

   // Rotate for I32
   VAR r I32 := 1;
   r := r #+% 3; // rotate up by 3 -> 8
   ASSERT(r == 8);
   r := r #-% 3; // rotate back by 3 -> 1
   ASSERT(r == 1);

   // Byte tests (8-bit expectations)
   VAR b1 BYTE := 6; // 0000 0110
   VAR b2 BYTE := 3; // 0000 0011
   VAR b BYTE;

   // Binary bitwise on BYTE
   b := b1 #&& b2; ASSERT(b == BYTE(@OTHER 2));  // 0000 0010
   b := b1 #|| b2; ASSERT(b == BYTE(@OTHER 7));  // 0000 0111
   b := b1 #^^ b2; ASSERT(b == BYTE(@OTHER 5));  // 0000 0101
   b := b1 #&! b2; ASSERT(b == BYTE(@OTHER 253)); // ~(6&3)=~2=253
   b := b1 #|! b2; ASSERT(b == BYTE(@OTHER 248)); // ~(6|3)=~7=248
   b := b1 #^! b2; ASSERT(b == BYTE(@OTHER 250)); // ~(6^3)=~5=250
   b := b1 #^> b2; ASSERT(b == BYTE(@OTHER 251));
   b := b1 #^< b2; ASSERT(b == BYTE(@OTHER 254));

   // Unary bitwise inverse for BYTE
   VAR bu BYTE := 170; // 1010 1010
   // UNIMPLEMENTED
   bu := bu #!!;       // -> 0101 0101 = 85
   ASSERT(bu == BYTE(@OTHER 85));

   // Shifts for BYTE
   VAR bs BYTE := 1;
   bs := bs #++ 3; ASSERT(bs == BYTE(@OTHER 8));
   bs := bs #-- 1; ASSERT(bs == BYTE(@OTHER 4));

   // Rotates for BYTE
   VAR br BYTE := 129;                             // 1000 0001
   br := br #+% 1; ASSERT(br == BYTE(@OTHER 3));   // 0000 0011
   br := br #-% 1; ASSERT(br == BYTE(@OTHER 129)); // back to 1000 0001
}

::bool_probe FUNCTION(@counter & I32, @value BOOL): BOOL
{
   counter := counter + 1;
   RETURN value;
}

::logical_operators_test STATIC_TEST
{
   ASSERT((TRUE && TRUE) == TRUE);
   ASSERT((TRUE && FALSE) == FALSE);
   ASSERT((FALSE || TRUE) == TRUE);
   ASSERT((FALSE || FALSE) == FALSE);
   ASSERT((TRUE ^^ FALSE) == TRUE);
   ASSERT((TRUE ^^ TRUE) == FALSE);
   ASSERT((TRUE ^! TRUE) == TRUE);
   ASSERT((TRUE ^! FALSE) == FALSE);
   ASSERT((TRUE &! TRUE) == FALSE);
   ASSERT((FALSE &! TRUE) == TRUE);
   ASSERT((TRUE |! FALSE) == FALSE);
   ASSERT((FALSE |! FALSE) == TRUE);
   ASSERT((TRUE ^> FALSE) == FALSE);
   ASSERT((FALSE ^> FALSE) == TRUE);
   ASSERT((FALSE ^< TRUE) == FALSE);
   ASSERT((TRUE ^< FALSE) == TRUE);
   ASSERT((TRUE !!) == FALSE);
   ASSERT((FALSE !!) == TRUE);

   VAR counter I32 := 0;

   ASSERT((FALSE && bool_probe(@counter counter, @value TRUE)) == FALSE);
   ASSERT(counter == 0);

   ASSERT((TRUE || bool_probe(@counter counter, @value FALSE)) == TRUE);
   ASSERT(counter == 0);

   ASSERT((FALSE ^> bool_probe(@counter counter, @value FALSE)) == TRUE);
   ASSERT(counter == 0);

   ASSERT((TRUE ^< bool_probe(@counter counter, @value FALSE)) == TRUE);
   ASSERT(counter == 0);

   ASSERT((TRUE && bool_probe(@counter counter, @value TRUE)) == TRUE);
   ASSERT(counter == 1);

   ASSERT((FALSE || bool_probe(@counter counter, @value TRUE)) == TRUE);
   ASSERT(counter == 2);

   ASSERT((TRUE ^> bool_probe(@counter counter, @value FALSE)) == FALSE);
   ASSERT(counter == 3);

   ASSERT((FALSE ^< bool_probe(@counter counter, @value TRUE)) == FALSE);
   ASSERT(counter == 4);
}
