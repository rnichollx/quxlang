::storage_buz_helper FUNCTION(): I32
{
  VAR slot STORAGE(buz);
  VAR p ->buz := PLACE AT(slot) buz;
  ASSERT(p??);
  ASSERT(buz_x(PUN slot AS buz) == 9);
  buz_inc(PUN slot AS buz);
  ASSERT(buz_x(PUN slot AS buz) == 10);
  DESTROY AT(slot) buz;

  VAR slot2 STORAGE(I32);
  VAR iptr ->I32 := PLACE AT(slot2) I32 := 9;
  ASSERT(iptr??);
  ASSERT((PUN slot2 AS I32) == 9);
  DESTROY AT(slot2) I32;
  RETURN 10;
}

