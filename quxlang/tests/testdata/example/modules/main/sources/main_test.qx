   VAR x I32 := 255;

   x.SERIALIZE( @OUTPUT_ITERATOR output[& 0] );

   ASSERT( output[0] ==  255 );
   ASSERT( output[1] ==  0 );
   ASSERT( output[2] ==  0 );
   ASSERT( output[3] ==  0 );
}

