::pointer_to_pointer_increment_test STATIC_TEST
{
  VAR x I32 := 5;
  VAR px ->I32 := x<-;
  VAR ppx -> ->I32 := px<-;
  VAR ppx2 -> ->I32 := ppx;
  ppx-> -> := 10;
  ASSERT(x == 10);
  ptrptr_incr(@ptr ppx);
}

::ptrptr_incr FUNCTION(@ptr CONST -> MUT-> I32)
{
  ptr-> -> ++;
}

