::postincrement_array_iterator_store_test STATIC_TEST
{

  VAR x [3]I32;

  VAR y =>> I32;
  y := x[& 0];

  (y++)-> := 10;
  (y++)-> := 20;
  (y++)-> := 30;

  ASSERT( x[0] == 10 );
  ASSERT( x[1] == 20 );
  ASSERT( x[2] == 30 );
}

::array_byte_pointer_load_store_test STATIC_TEST
{
  VAR x [4]BYTE;

  VAR z =>> BYTE;

  z := x[& 0];

  VAR z2 =>> BYTE;
  z2 := z;

  z-> := 42;

  ASSERT( x[0] == 42 );

  z2-> := 84;

  ASSERT( x[0] == 84 );
}


::static_choose_import_test STATIC_TEST
{
   VAR x I32;

   x := STATIC_CHOOSE( foolib::imported_function() == 42 , 10 , 20 );
   ASSERT( x == 10 );

   x := STATIC_CHOOSE( foolib::imported_function() != 42 , 10 , 20 );
   ASSERT( x == 20 );
}

