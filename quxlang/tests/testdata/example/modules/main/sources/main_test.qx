::symmetric_comparison_operators_test STATIC_TEST
{
    VAR x I32 := 5;

    ASSERT( x == 5 );
    ASSERT( 5 == x );

    ASSERT( x != 6 );
    ASSERT( 6 != x );

    ASSERT( x < 6 );
    ASSERT( 4 < x );

    ASSERT( x > 4 );
    ASSERT( 6 > x );

    ASSERT( x >= 5 );
    ASSERT( 6 >= x );

    ASSERT( x <= 6 );
    ASSERT( 5 <= x );

    ASSERT( x >= 4 );
    ASSERT( 4 <= x );
}

