
::string CLASS
  STRINGLIKE SERIALOID
{
   .data VAR =>>STORAGE(BYTE);
   .length VAR SZ;
   .capacity VAR SZ;

   .CONSTRUCTOR FUNCTION()
   {
   }

   .CONSTRUCTOR FUNCTION( @OTHER STRING_CONSTANT )
   {
      VAR len SZ := (OTHER.END() - OTHER.BEGIN()) AS ASSUME SZ;
      RUNTIME CONSTEXPR {
        .data := CONSTEXPR_ALLOC_MULTIPLE#BYTE(len);
        .capacity := len;
        WHILE ( .length < len )
        {
           PLACE AT(.data[.length]) BYTE := OTHER.BEGIN()[.length];
           .length++;
        }
      } ELSE {
        // Native runtime, need to write standard library allocator first
        UNIMPLEMENTED;
      }
   }

   .push_back FUNCTION( @value BYTE )
   {
     IF ( .capacity <= .length )
     {
        .reserve(@capacity .capacity*2);
     }
     PLACE AT(.data[.length]) BYTE := value;
     .length++;

   }

   .reserve FUNCTION( @capacity SZ )
   {
      RUNTIME NATIVE
      {
         UNIMPLEMENTED;
      }
      VAR original_capacity SZ := .capacity;
      IF ( .capacity < capacity )
      {
         VAR new_data =>>STORAGE(BYTE) := CONSTEXPR_ALLOC_MULTIPLE#BYTE(capacity);
         VAR i SZ := 0;
         WHILE ( i < .length )
         {
            PLACE AT(new_data[i]) BYTE := PUN .data[i] AS BYTE;
            i++;
         }
         IF ( original_capacity > 0 )
         {
            CONSTEXPR_DEALLOC_MULTIPLE#BYTE(.data, original_capacity);
         }
         .data := new_data;
         .capacity := capacity;
      }
   }

   .pop_back FUNCTION()
   {
      DESTROY AT(.data + .length - 1) BYTE;
      .length--;
   }

   .OPERATOR+ FUNCTION(@OTHER CONST& string): string
   {
     VAR result string;

     VAR total_length SZ := .length + OTHER.length;

        result.reserve(@capacity total_length);

        VAR i SZ := 0;
        WHILE ( i < .length )
        {
           VAR current BYTE := PUN .data[i] AS BYTE;
           result.push_back(@value BYTE(@OTHER current));
           i++;
        }
        i := 0;
        WHILE (i < OTHER.length )
        {
           VAR current BYTE := PUN OTHER.data[i] AS BYTE;
           result.push_back(@value BYTE(@OTHER current));
           i++;
        }

        RETURN result;
   }

   .OPERATOR== FUNCTION(@OTHER CONST& string): BOOL
   {
      IF ( .length != OTHER.length )
      {
         RETURN FALSE;
      }
      VAR i SZ := 0;
      WHILE ( i < .length )
      {
         IF ( THIS[i] != OTHER[i] )
         {
            RETURN FALSE;
         }
         i++;
      }
      RETURN TRUE;
   }

   .OPERATOR[] FUNCTION(%index SZ):  BYTE
   {
      IF ( index >= .length )
     {
         ASSERT(FALSE);
      }
      VAR result BYTE := PUN .data[index] AS BYTE;
      RETURN result;
   }

   .SERIALIZE FUNCTION(@OUTPUT_ITERATOR:out AUTO(it)): it
   {
     out := SERIALIZE_UINTANY(@OUTPUT_ITERATOR out, @VALUE .length);
     VAR i SZ := 0;
     WHILE ( i < .length )
     {
       out++ -> := THIS[i];
       i++;
     }
     RETURN out;
   }

   .DESERIALIZE FUNCTION(@INPUT_ITERATOR:input AUTO(it)): it
   {
     VAR len SZ := 0;
     input := DESERIALIZE_UINTANY(@INPUT_ITERATOR input, @VALUE len);
     .length := 0;
     .reserve(@capacity len);
     VAR i SZ := 0;
     WHILE ( i < len )
     {
       .push_back(@value (input++)->);
       i++;
     }
     RETURN input;
   }
}

::string_tests STATIC_TEST
{
  VAR str1 string := "Hello, ";
  VAR str2 string := "world!";
  VAR str3 string := str1 + str2;

  ASSERT(str3 == "Hello, world!");

  ASSERT(str3 == static_string);
}

::get_static_string FUNCTION(): string
{
   RETURN ("Hello, " AS string) + ("world!" AS string);
}

::static_string_object STATIC string := get_static_string();
::static_string STATIC STRING_CONSTANT := static_string_object;
