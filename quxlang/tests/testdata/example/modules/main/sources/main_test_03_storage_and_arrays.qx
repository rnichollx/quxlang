::constexpr_alloc_use_after_free_pointer_ops_test STATIC_TEST EXPECT_FAIL
{
  VAR count SZ := 2;
  VAR slots =>> STORAGE(BYTE) := CONSTEXPR_ALLOC_MULTIPLE#BYTE(count);
  VAR freed_slots =>> STORAGE(BYTE) := slots;
  CONSTEXPR_DEALLOC_MULTIPLE#BYTE(slots, count);
  freed_slots++;
}

