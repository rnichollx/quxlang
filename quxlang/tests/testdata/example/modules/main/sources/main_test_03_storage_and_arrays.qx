{
  VAR count SZ := 2;
  VAR slots =>> STORAGE(BYTE) := CONSTEXPR_ALLOC_MULTIPLE#BYTE(count);
  CONSTEXPR_DEALLOC_MULTIPLE#BYTE(slots, 3);
}

