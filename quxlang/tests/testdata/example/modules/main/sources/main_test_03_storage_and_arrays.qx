::constexpr_alloc_use_after_free_pun_test STATIC_TEST EXPECT_FAIL
{
  VAR slot_ptr -> STORAGE(I32) := CONSTEXPR_ALLOC#I32();
  PLACE AT(slot_ptr->) I32 := 5;
  DESTROY AT(slot_ptr->) I32;
  VAR freed_ptr -> STORAGE(I32) := slot_ptr;
  CONSTEXPR_DEALLOC#I32(slot_ptr);
  ASSERT((PUN (freed_ptr->) AS I32) == 5);
}

::constexpr_alloc_use_after_free_place_test STATIC_TEST EXPECT_FAIL
{
  VAR slot_ptr -> STORAGE(I32) := CONSTEXPR_ALLOC#I32();
  VAR freed_ptr -> STORAGE(I32) := slot_ptr;
  CONSTEXPR_DEALLOC#I32(slot_ptr);
  PLACE AT(freed_ptr->) I32 := 7;
}

