::pointer_to_pointer_increment_test STATIC_TEST
{
  VAR x I32 := 5;
  VAR px ->I32 := x<-;
  VAR ppx -> ->I32 := px<-;
  VAR ppx2 -> ->I32 := ppx;
  ppx-> -> := 10;
  ASSERT(x == 10);
  ptrptr_incr(@ptr ppx);
}

::ptrptr_incr FUNCTION(@ptr CONST-> MUT-> I32)
{
  ptr-> -> ++;
}

::global VAR I32 := 8;

::antestatal_static_i32 STATIC I32 := 4;

::antestatal_static_i32_ptr STATIC CONST -> I32 := antestatal_static_i32<-;

::antestatal_static_proc STATIC CONST -> PROCEDURE(I32, I32: I32) := foo<-;

::global_tmpl TEMPLATE( @foo TYPE AUTO(t) ) VAR t := 1;


::mutable_global_and_template_global_test STATIC_TEST
{
  ASSERT(global == 8);
  global := global + 2;
  ASSERT(global == 10);

  ASSERT(global_tmpl#(@foo I32) == 1);
  global_tmpl#(@foo I32) := 5;
  ASSERT(global_tmpl#(@foo I32) == 5);
  ASSERT(global_tmpl#(@foo I64) == 1);

}

::antestatal_static_values_test STATIC_TEST
{
  ASSERT(antestatal_static_i32 == 4);
  ASSERT(antestatal_static_i32_ptr-> == 4);
  ASSERT(antestatal_static_proc(4, 5) == 9);
  // TODO: Add a negative constexpr test that verifies mutating an antestatal static is rejected.

}


::templated_holder TEMPLATE(TYPE AUTO(t)) CLASS
{
  .value VAR t;
}

::templated_holder_value_test STATIC_TEST
{
  VAR holder templated_holder#( I32 );
  holder.value := 5;
  ASSERT(holder.value == 5);

  holder.value := 9;

  ASSERT(holder.value == 9);
}

::value_template_holder TEMPLATE(@count:value_count VALUE U64) CLASS
{
  .stored VAR U64;

  .fill FUNCTION(): U64
  {
    VAR values [value_count]U64;
    VAR local U64 := value_count;
    values[0] := local;
    values[1] := local + 1;
    .stored := value_count;
    RETURN values[1];
  }
}

::value_template_argument_test STATIC_TEST
{
  VAR holder value_template_holder#(@count 4);
  ASSERT(holder.fill() == 5);
  ASSERT(holder.stored == 4);
}

::postincrement_array_iterator_store_test STATIC_TEST
{

  VAR x [3]I32;

  VAR y =>> I32;
  y := x[& 0];

  (y++)-> := 10;
  (y++)-> := 20;
  (y++)-> := 30;

  ASSERT( x[0] == 10 );
  ASSERT( x[1] == 20 );
  ASSERT( x[2] == 30 );
}

::array_byte_pointer_load_store_test STATIC_TEST
{
  VAR x [4]BYTE;

  VAR z =>> BYTE;

  z := x[& 0];

  VAR z2 =>> BYTE;
  z2 := z;

  z-> := 42;

  ASSERT( x[0] == 42 );

  z2-> := 84;

  ASSERT( x[0] == 84 );
}


::static_choose_import_test STATIC_TEST
{
   VAR x I32;

   x := STATIC_CHOOSE( foolib::imported_function() == 42 , 10 , 20 );
   ASSERT( x == 10 );

   x := STATIC_CHOOSE( foolib::imported_function() != 42 , 10 , 20 );
   ASSERT( x == 20 );
}

::static_counter_probe FUNCTION(@counter MUT& I32, @value BOOL) : BOOL
{
   counter++;
   RETURN value;
}

::static_var_loop_expansion_test STATIC_TEST
{
   VAR foo I32 := 0;
   STATIC_VAR x I32 := 1;
   STATIC_WHILE (x < 5) {
      foo++;
      STATIC_EVAL x++;
   }
   ASSERT(foo == 4);
}

::static_while_zero_iterations_test STATIC_TEST
{
   VAR foo I32 := 0;
   STATIC_VAR x I32 := 0;
   STATIC_WHILE (FALSE) {
      foo++;
      STATIC_EVAL x++;
   }
   ASSERT(foo == 0);
   ASSERT(SNAPSHOT(x) == 0);
}

::static_while_condition_mutation_test STATIC_TEST
{
   VAR foo I32 := 0;
   STATIC_VAR x I32 := 0;
   STATIC_WHILE (static_counter_probe(@counter x, @value x < 3)) {
      foo++;
   }
   ASSERT(foo == 3);
   ASSERT(SNAPSHOT(x) == 4);
}

::static_if_selected_branch_test STATIC_TEST
{
   STATIC_VAR x I32 := 0;
   STATIC_IF (FALSE) {
      STATIC_EVAL x := 99;
   } STATIC_ELSE {
      STATIC_EVAL x++;
   }
   VAR y I32 := SNAPSHOT(x);
   ASSERT(y == 1);
}

::static_if_condition_mutation_test STATIC_TEST
{
   STATIC_VAR x I32 := 0;
   STATIC_IF (static_counter_probe(@counter x, @value TRUE)) {
      STATIC_EVAL x++;
   } STATIC_ELSE {
      STATIC_EVAL x := 99;
   }
   VAR y I32 := SNAPSHOT(x);
   ASSERT(y == 2);
}

::static_if_unselected_branch_not_generated_test STATIC_TEST
{
   STATIC_IF (TRUE) {
      VAR x I32 := 1;
      ASSERT(x == 1);
   } STATIC_ELSE {
      VAR y I32 := bogus_unselected;
      ASSERT(y == 2);
   }
}

::static_choose_unselected_expression_not_generated_test STATIC_TEST
{
   VAR chosen_a I32 := STATIC_CHOOSE(TRUE, 7, bogus_choice_a);
   VAR chosen_b I32 := STATIC_CHOOSE(FALSE, bogus_choice_b, 11);
   ASSERT(chosen_a == 7);
   ASSERT(chosen_b == 11);
}

::static_default_and_call_initializers_test STATIC_TEST
{
   STATIC x I32;
   STATIC y I32 :(@OTHER 7);
   ASSERT(x == 0);
   ASSERT(y == 7);
}

::static_snapshot_read_after_mutation_test STATIC_TEST
{
   STATIC_VAR x I32 := 1;
   STATIC_VAR z -> I32 := x<-;
   VAR before CONST->I32 := SNAPSHOT(z);
   STATIC_EVAL x++;
   VAR after CONST->I32 := SNAPSHOT(z);
   ASSERT(before-> == 1);
   ASSERT(after-> == 2);
}

::static_var_nested_block_snapshot_test STATIC_TEST
{
   STATIC_VAR outer I32 := 1;
   ASSERT(SNAPSHOT(outer) == 1);
   {
      STATIC_VAR inner I32 := 5;
      ASSERT(SNAPSHOT(inner) == 5);
      STATIC_EVAL inner++;
      ASSERT(SNAPSHOT(inner) == 6);
      ASSERT(SNAPSHOT(outer) == 1);
   }
   ASSERT(SNAPSHOT(outer) == 1);
}

::static_var_shadowed_block_rejected_test STATIC_TEST EXPECT_COMPILATION_FAILURE
{
   STATIC_VAR x I32 := 1;
   {
      STATIC_VAR x I32 := 5;
   }
   ASSERT(SNAPSHOT(x) == 1);
}

::runtime_if_static_generation_order_test STATIC_TEST
{
   STATIC_VAR x I32 := 0;
   IF (TRUE) {
      STATIC_EVAL x++;
   } ELSE {
      STATIC_EVAL x++;
   }
   VAR y I32 := SNAPSHOT(x);
   ASSERT(y == 2);
}

::runtime_while_static_generation_once_test STATIC_TEST
{
   STATIC_VAR x I32 := 0;
   VAR i I32 := 0;
   WHILE (i < 5) {
      STATIC_EVAL x++;
      i++;
   }
   VAR y I32 := SNAPSHOT(x);
   ASSERT(y == 1);
}

::runtime_for_loop_test STATIC_TEST
{
   VAR sum I32 := 0;
   FOR INIT { VAR i I32 := 0; } TEST(i < 5) STEP { i++; } LOOP {
      sum := sum + i;
   };
   ASSERT(sum == 10);
}

::runtime_for_posttest_loop_test STATIC_TEST
{
   VAR count I32 := 0;
   VAR i I32 := 0;
   FOR POSTTEST(i < 3) STEP { i++; } LOOP {
      count++;
   };
   ASSERT(count == 4);
}

::runtime_while_break_continue_test STATIC_TEST
{
   VAR sum I32 := 0;
   VAR i I32 := 0;
   WHILE (i < 8) {
      i++;
      IF (i == 2) {
         CONTINUE;
      }
      IF (i == 5) {
         BREAK;
      }
      sum := sum + i;
   }
   ASSERT(sum == 8);
}

::runtime_for_break_continue_test STATIC_TEST
{
   VAR sum I32 := 0;
   FOR INIT { VAR i I32 := 0; } TEST(i < 8) STEP { i++; } LOOP {
      IF (i == 2) {
         CONTINUE;
      }
      IF (i == 5) {
         BREAK;
      }
      sum := sum + i;
   };
   ASSERT(sum == 8);
}

::runtime_for_sequence_to_loop_test STATIC_TEST
{
   VAR sum I32 := 0;
   VAR two I32 := 2;
   FOR VALUE(i) FROM(0 AS I32) TO(10) BY(two) LOOP {
      sum := sum + i;
   };
   ASSERT(sum == 30);
}

::runtime_for_sequence_until_loop_test STATIC_TEST
{
   VAR sum I32 := 0;
   FOR VALUE(i) FROM(0 AS I32) UNTIL(5) LOOP {
      sum := sum + i;
   };
   ASSERT(sum == 10);
}

::runtime_for_sequence_filter_loop_test STATIC_TEST
{
   VAR sum I32 := 0;
   FOR VALUE(i) FROM(0 AS I32) TO(6) FILTER((i == 0) || (i == 2) || (i == 4) || (i == 6)) LOOP {
      sum := sum + i;
   };
   ASSERT(sum == 12);
}

::runtime_for_sequence_break_continue_test STATIC_TEST
{
   VAR sum I32 := 0;
   FOR FROM(0 AS I32) TO(8) VALUE(i) LOOP {
      IF (i == 2) {
         CONTINUE;
      }
      IF (i == 5) {
         BREAK;
      }
      sum := sum + i;
   };
   ASSERT(sum == 8);
}

::runtime_labeled_for_control_test STATIC_TEST
{
   VAR sum I32 := 0;
   FOR :outer FROM(0 AS I32) TO(4) VALUE(i) LOOP {
      FOR :inner FROM(0 AS I32) TO(4) VALUE(j) LOOP {
         IF (j == 1) {
            CONTINUE :outer;
         }
         sum := sum + 1;
      }
   };
   ASSERT(sum == 5);

   FOR :stop FROM(0 AS I32) TO(4) VALUE(i) LOOP {
      FOR FROM(0 AS I32) TO(4) VALUE(j) LOOP {
         BREAK :stop;
      }
      sum := sum + 100;
   };
   ASSERT(sum == 5);
}

::runtime_labeled_while_control_test STATIC_TEST
{
   VAR i I32 := 0;
   VAR sum I32 := 0;
   WHILE :outer (i < 5) {
      i++;
      VAR j I32 := 0;
      WHILE :inner (j < 3) {
         j++;
         CONTINUE :outer;
      }
      sum++;
   }
   ASSERT(sum == 0);
}

::runtime_labeled_block_break_test STATIC_TEST
{
   VAR x I32 := 0;
   LABEL :done {
      x := 1;
      BREAK :done;
      x := 99;
   }
   ASSERT(x == 1);
}

::runtime_forward_goto_test STATIC_TEST
{
   VAR x I32 := 0;
   GOTO :skip;
   x := 99;
   LABEL :skip;
   ASSERT(x == 0);
}

::runtime_backward_goto_test STATIC_TEST
{
   VAR x I32 := 0;
   LABEL :again;
   x++;
   IF (x < 3) {
      GOTO :again;
   }
   ASSERT(x == 3);
}

::runtime_goto_out_of_block_test STATIC_TEST
{
   VAR x I32 := 0;
   {
      VAR y I32 := 1;
      x := y;
      GOTO :after;
   }
   LABEL :after;
   ASSERT(x == 1);
}

::missing_break_label_fails_test STATIC_TEST EXPECT_COMPILATION_FAILURE
{
   BREAK :missing;
}

