::buf FUNCTION(%a MUT& I32)
{
    VAR zz yak;
    zz.z := a<-;
}

::biz FUNCTION(%a I32, %b I32): I32
{
  VAR y I32;
  VAR q [3]I32;
  q[0] := 1;
  q[1] := 2;
  q[2] := 3;

  IF (y == 0)
  {
    VAR x yak;
    x.z := y<-;
    x.f := q[& 0];
    x.f_count := 3;
  }
  buf(a);
  RETURN a + b + y + q[0] + q[1] + q[2] + 1;
}


::mif FUNCTION(): I64
{
  VAR x [4]I64;
  x[0] := 1;
  x[1] := 2;
  x[2] := 3;
  x[3] := 4;


  RETURN x[0] + x[1] + x[2] + x[3];
}


// [4]->I32
// ->  [4]I32
// ->  [4]->I32
// =>> I32
// [4]I32

// *I32
// ^I32


::boq FUNCTION(): I32
{
  RETURN 5;
}

::boq FUNCTION(%a I32): I32
{
  RETURN a + 5;
}

::yip FUNCTION(%a AUTO(t1)) : t1
{
  RETURN a + 1;
}

::deduced_auto_return FUNCTION(%a AUTO(t1)) : AUTO
{
  RETURN a;
}

::deduced_const_ref_return FUNCTION(%a MUT& I32) : CONST& AUTO
{
  RETURN a;
}

::deduced_auto_ref_return FUNCTION(%a MUT& I32) : AUTO& AUTO
{
  RETURN a;
}

::forward_ref_value FUNCTION(%a AUTO& AUTO): I32
{
  RETURN FORWARD(a);
}

::decltype_parameter_return FUNCTION(%a AUTO& AUTO): DECLTYPE(a)
{
  RETURN FORWARD(a);
}

::typeof_side_effect_probe FUNCTION(@target WRITE& I32): I32
{
  target := 44;
  RETURN 7;
}

::fibbonachi FUNCTION(@n AUTO): AUTO
{
  IF (n <= 1)
  {
    RETURN n;
  }
  RETURN fibbonachi(@n n - 1) + fibbonachi(@n n - 2);
}

::self_recursive_auto_return_test STATIC_TEST
{
  ASSERT( fibbonachi(@n 0 AS I32) == 0 );
  ASSERT( fibbonachi(@n 1 AS I32) == 1 );
  ASSERT( fibbonachi(@n 5 AS I32) == 5 );
  ASSERT( fibbonachi(@n 10 AS I64) == 55 );
}

::yip FUNCTION(): I32
{
  VAR x I32;
  x := 7;
  RETURN yip(x);
}

::overload_resolution_test STATIC_TEST
{
  ASSERT( boq() == 5 );
  ASSERT( boq(10) == 15 );
  ASSERT( yip() == 8 );
  ASSERT( deduced_auto_return(11 AS I32) == 11 );

  VAR ref_source I32 := 12;
  VAR const_ref CONST& I32 := deduced_const_ref_return(ref_source);
  VAR mut_ref MUT& I32 := deduced_auto_ref_return(ref_source);

  ASSERT( const_ref == 12 );
  mut_ref := 13;
  ASSERT( ref_source == 13 );
}

::type_expression_bits_sizeof_test STATIC_TEST
{
  VAR x I32;
  x := 4;

  // ASSERT( SIZEOF(I32) == 4  );

  ASSERT( SIZEOF(I32)  == x );

  x := 32;

  ASSERT( BITS(I32) == x );


}

::pointer_qualifier_probe FUNCTION(%p MUT -> I32): I32
{
  RETURN 1;
}

::pointer_qualifier_probe FUNCTION(%p CONST -> I32): I32
{
  RETURN 2;
}

::procedure_pointer_probe FUNCTION(%p CONST -> PROCEDURE(I32, I32: I32)): I32
{
  RETURN 1;
}

::procedure_pointer_parse_probe FUNCTION(%p CONST -> PROCEDURE CCALL NOEXCEPT(I32, I32: I32)): I32
{
  RETURN 2;
}

::reference_qualifier_address_of_test STATIC_TEST
{
  VAR x I32 := 7;
  VAR cx CONST& I32 := x;

  ASSERT( pointer_qualifier_probe(x<-) == 1 );
  ASSERT( pointer_qualifier_probe(cx<-) == 2 );
}


::vfunc FUNCTION(@val & I32)
{
    val := val + 1;
}

::procedure_pointer_call_test STATIC_TEST
{
  VAR proc CONST -> PROCEDURE(I32, I32: I32) := foo<-;
  ASSERT( procedure_pointer_probe(proc) == 1 );
  ASSERT( proc(4, 5) == 9 );

  proc := bar<-;
  ASSERT( proc(4, 5) == 20 );
  proc := foo<-;

  VAR proc_ref CONST& PROCEDURE(I32, I32: I32) := proc->;
  ASSERT( proc_ref(6, 7) == 13 );

  VAR mutproc CONST -> PROCEDURE(@val & I32) := vfunc<-;
  VAR x I32 := 10;
  mutproc(@val x);
  ASSERT(x == 11);
}


::include_if_helper FUNCTION(%a AUTO(t1)) ENABLE_IF( BITS(t1) < 32 AS I32 ): I32
{
  RETURN 1;
}

::include_if_helper FUNCTION(%a AUTO(t1)) ENABLE_IF( BITS(t1) == 32 AS I64 ): I32
{
  RETURN 2;
}

::include_if_helper FUNCTION(%a AUTO(t1)) ENABLE_IF( BITS(t1) > 32 AS I32 ): I32
{
  RETURN 3;
}
::include_if_overload_resolution_test STATIC_TEST
{
    VAR x I32;

    x := include_if_helper( 0 AS I16 );
    ASSERT( x == 1 );

    x := include_if_helper( 0 AS I32 );
    ASSERT( x == 2 );

    x := include_if_helper( 0 AS I64 );
    ASSERT( x == 3 );
}

::forward_decltype_typeof_test STATIC_TEST
{
  VAR x I32 := 12;

  ASSERT(SAME_TYPES(DECLTYPE(x), I32));
  ASSERT(SAME_TYPES(TYPEOF(x), MUT& I32));
  ASSERT(SAME_TYPES(TYPEOF(typeof_side_effect_probe(@target x)), I32));
  ASSERT(x == 12);
  ASSERT(forward_ref_value(x) == 12);
  VAR y I32 := decltype_parameter_return(x);
  ASSERT(y == 12);
}

::forward_non_reference_value_test STATIC_TEST EXPECT_COMPILATION_FAILURE
{
  VAR x I32 := 12;
  VAR y I32 := FORWARD(x);
}

::pack_count FUNCTION(%a I32, %...b I32): I32
{
    RETURN PACK_SIZE(b) AS I32;
}

::pack_pick_second FUNCTION(%a I32, %...b I32): I32
{
    RETURN PACK_ARG(b, 1);
}

::pack_first FUNCTION(%...b AUTO): PACK_ARG_TYPE(b, 0)
{
    RETURN PACK_ARG(b, 0);
}

::pack_first_is_i32 FUNCTION(%...b AUTO): BOOL
{
    RETURN SAME_TYPES(PACK_ARG_TYPE(b, 0), I32);
}

::pack_arg_type_variable FUNCTION(%...b AUTO): I32
{
    VAR x PACK_ARG_TYPE(b, 0) := PACK_ARG(b, 0);
    RETURN x;
}

::pack_enable_if_helper FUNCTION(%...b AUTO) ENABLE_IF(SAME_TYPES(PACK_ARG_TYPE(b, 0), I32)): I32
{
    RETURN 1;
}

::pack_enable_if_helper FUNCTION(%...b AUTO) ENABLE_IF(SAME_TYPES(PACK_ARG_TYPE(b, 0), I64)): I32
{
    RETURN 2;
}

::pack_size_enable_if_helper FUNCTION(%...b I32) ENABLE_IF(PACK_SIZE(b) == 1 AS I32): I32
{
    RETURN 1;
}

::pack_size_enable_if_helper FUNCTION(%...b I32) ENABLE_IF(PACK_SIZE(b) == 2 AS I32): I32
{
    RETURN 2;
}

::pack_overload FUNCTION(%a I32): I32
{
    RETURN 1;
}

::pack_overload FUNCTION(%a I32, %...b I32): I32
{
    RETURN 2;
}

::pack_prefix FUNCTION(%a I32, %...b I32): I32
{
    RETURN 1;
}

::pack_prefix FUNCTION(%a I32, %b I32, %...c I32): I32
{
    RETURN 2;
}

::pack_hetero FUNCTION(%...b AUTO): BOOL
{
    RETURN SAME_TYPES(PACK_ARG_TYPE(b, 0), I32) && SAME_TYPES(PACK_ARG_TYPE(b, 1), I64);
}

::pack_same_type FUNCTION(%...b AUTO(t1)): I32
{
    RETURN PACK_SIZE(b) AS I32;
}

::pack_repeated_auto FUNCTION(%a AUTO(t1), %b AUTO(t1)): I32
{
    RETURN 1;
}

::pack_ambiguous_variadic FUNCTION(%...b AUTO(t1)): I32
{
    RETURN 1;
}

::pack_ambiguous_variadic FUNCTION(%...b AUTO(t2)): I32
{
    RETURN 2;
}

::pack_static_var_sum FUNCTION(%...b I32): I32
{
    VAR result I32 := 0;
    STATIC_VAR i U64 := 0;
    STATIC_WHILE (i < PACK_SIZE(b)) {
        result := result + PACK_ARG(b, i);
        STATIC_EVAL i++;
    }
    RETURN result;
}

::variadic_argument_pack_test STATIC_TEST
{
    ASSERT(pack_count(1) == 0);
    ASSERT(pack_count(1, 2, 3) == 2);
    ASSERT(pack_pick_second(1, 2, 7) == 7);
    ASSERT(pack_first(4 AS I32, 5 AS I64) == 4);
    ASSERT(pack_first_is_i32(4 AS I32, 5 AS I64) == TRUE);
    ASSERT(pack_arg_type_variable(9 AS I32) == 9);
    ASSERT(pack_enable_if_helper(0 AS I32) == 1);
    ASSERT(pack_enable_if_helper(0 AS I64) == 2);
    ASSERT(pack_size_enable_if_helper(1) == 1);
    ASSERT(pack_size_enable_if_helper(1, 2) == 2);
    ASSERT(pack_overload(1) == 1);
    ASSERT(pack_overload(1, 2) == 2);
    ASSERT(pack_prefix(1, 2) == 2);
    ASSERT(pack_hetero(1 AS I32, 2 AS I64) == TRUE);
    ASSERT(pack_same_type(1 AS I32, 2 AS I32) == 2);
    ASSERT(pack_repeated_auto(1 AS I32, 2 AS I32) == 1);
    ASSERT(pack_static_var_sum() == 0);
    ASSERT(pack_static_var_sum(4) == 4);
    ASSERT(pack_static_var_sum(1, 2, 3) == 6);
}

::pack_same_type_mismatch_test STATIC_TEST EXPECT_COMPILATION_FAILURE
{
    VAR x I32 := pack_same_type(1 AS I32, 2 AS I64);
}

::pack_repeated_auto_mismatch_test STATIC_TEST EXPECT_COMPILATION_FAILURE
{
    VAR x I32 := pack_repeated_auto(1 AS I32, 2 AS I64);
}

::pack_ambiguous_variadic_test STATIC_TEST EXPECT_COMPILATION_FAILURE
{
    VAR x I32 := pack_ambiguous_variadic(1 AS I32);
}

::pack_arg_out_of_range FUNCTION(%...b I32): I32
{
    RETURN PACK_ARG(b, 1);
}

::pack_arg_type_out_of_range FUNCTION(%...b I32): PACK_ARG_TYPE(b, 1)
{
    RETURN 0;
}

::pack_arg_type_out_of_range_test STATIC_TEST EXPECT_COMPILATION_FAILURE
{
    VAR x I32 := pack_arg_type_out_of_range(1);
}

::pack_direct_use FUNCTION(%...b I32): I32
{
    RETURN b;
}
