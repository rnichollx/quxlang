::arch_int INCLUDE_IF(ARCH_X64 && OS_LINUX ) FUNCTION(): I32
{
  RETURN 2;
}

::arch_int INCLUDE_IF(ARCH_ARM64) FUNCTION(): I32
{
  RETURN 1;
}

