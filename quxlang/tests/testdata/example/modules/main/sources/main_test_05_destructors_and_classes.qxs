LANGUAGE QUXLANG EN 0.0;

::symmetric_comparison_operators_test STATIC_TEST
{
    VAR x I32 := 5;

    ASSERT( x == 5 );
    ASSERT( 5 == x );

    ASSERT( x != 6 );
    ASSERT( 6 != x );

    ASSERT( x < 6 );
    ASSERT( 4 < x );

    ASSERT( x > 4 );
    ASSERT( 6 > x );

    ASSERT( x >= 5 );
    ASSERT( 6 >= x );

    ASSERT( x <= 6 );
    ASSERT( 5 <= x );

    ASSERT( x >= 4 );
    ASSERT( 4 <= x );
}

::bits_type_expression_test STATIC_TEST
{
   VAR xbits I32;
   xbits := BITS(I32);
   ASSERT(xbits == 32);
   VAR b BOOL;
   b := BITS(I16) < 32 AS I32;
   ASSERT( b == TRUE );
}

::yak_dtors FUNCTION(%a yak, %b &I32): I32
{
  a.z := b<-;
  RETURN 1;
}

::destructor_execution_test STATIC_TEST
{
  VAR x I32;

  {
    VAR y yak;
    y.z := x<-;
  }

  ASSERT (x == 1);

  yak_dtors(yak() , x);

  ASSERT (x == 2);
}

::array_pointer_destructor_test STATIC_TEST
{
  VAR x [4]I32;
  x[0] := 1;
  x[1] := 2;
  x[2] := 3;
  x[3] := 4;

  {
    VAR y yak;

    y.f := x[& 0];
    y.f_count := 3;
  }


  ASSERT (x[0] == 2);
  ASSERT (x[1] == 3);
  ASSERT (x[2] == 4);
  ASSERT (x[3] == 4);
}


::lambda_helper FUNCTION()
{
  UNIMPLEMENTED;
  VAR x I32;

 // AUTO z := -<
 // {
 //   x++;
 // };

}

::bam CLASS
{
  .x VAR I32;
  .y VAR -> I32;

  .CONSTRUCTOR FUNCTION(@OTHER CONST& bam)
  {
    .x := OTHER.x;
    .y := OTHER.y;
  }

  ::static_function FUNCTION(): I32
  {
    RETURN 3;
  }

  .CONSTRUCTOR FUNCTION(@OTHER TEMP& bam)
  {
    .x <-> OTHER.x;
    .y <-> OTHER.y;
  }

  .DESTRUCTOR FUNCTION()
  {
    IF (.y??)
    {
        .y-> := .y-> + 1;
    }
  }
}


::roman CLASS
{
  .value VAR I32;

  .CONSTRUCTOR FUNCTION(@OTHER STRING_CONSTANT)
  {
     VAR it CONST=>> BYTE := OTHER.BEGIN();
     VAR end CONST=>> BYTE := OTHER.END();

     WHILE (it < end)
     {
        IF (it-> == 'I')
        {
          .value := .value + 1;
        }
        ELSE IF (it-> == ("V" AS STRING_CONSTANT).BEGIN()->)
        {
          .value := .value + 5;
        }
        it++;
     }
  }

}

::swap_operator_test STATIC_TEST
{
    VAR a I32;
    VAR y I32;

    a := 5;
    y := 10;

    a <-> y;

    ASSERT(a == 10);
    ASSERT(y == 5);
}

::cross_file_function_call_test STATIC_TEST
{
  VAR x I32;

  x := other_file_function();

  ASSERT(x == 42);
}


::imported_function_call_test STATIC_TEST
{
   VAR x I32;

   x := foolib::imported_function();

   ASSERT(x == 42);
}

::array_pointer_arithmetic_test STATIC_TEST
{
  VAR a [4]I32;
  VAR ptr1 =>> I32;
  VAR ptr2 =>> I32;

  ptr1 := a[& 0];
  ptr2 := a[& 1];

  ASSERT(ptr1 < ptr2);

  ASSERT(ptr2 > ptr1);

  ASSERT(ptr1 != ptr2);

  ptr1++;

  ASSERT(ptr1 == ptr2);
}

::roman_numeral_conversion_test STATIC_TEST
{
  VAR r roman;
  VAR i I32 := 4;
  ASSERT(i == 4);
  r := "VIII" AS STRING_CONSTANT AS roman;

  ASSERT(r.value == 8);

}

