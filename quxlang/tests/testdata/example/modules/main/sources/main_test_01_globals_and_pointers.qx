::pointer_to_pointer_increment_test STATIC_TEST
{
  VAR x I32 := 5;
  VAR px ->I32 := x<-;
  VAR ppx -> ->I32 := px<-;
  VAR ppx2 -> ->I32 := ppx;
  ppx-> -> := 10;
  ASSERT(x == 10);
  ptrptr_incr(@ptr ppx);
}

::ptrptr_incr FUNCTION(@ptr CONST -> MUT-> I32)
{
  ptr-> -> ++;
}

::global VAR I32 := 8;

::antestatal_static_i32 STATIC I32 := 4;

::antestatal_static_i32_ptr STATIC CONST -> I32 := antestatal_static_i32<-;

::antestatal_static_proc STATIC CONST -> PROCEDURE(I32, I32: I32) := foo<-;

::global_tmpl TEMPLATE( @foo TYPE AUTO(t) ) VAR t := 1;


::mutable_global_and_template_global_test STATIC_TEST
{
  ASSERT(global == 8);
  global := global + 2;
  ASSERT(global == 10);

  ASSERT(global_tmpl#(@foo I32) == 1);
  global_tmpl#(@foo I32) := 5;
  ASSERT(global_tmpl#(@foo I32) == 5);
  ASSERT(global_tmpl#(@foo I64) == 1);

}

::antestatal_static_values_test STATIC_TEST
{
  ASSERT(antestatal_static_i32 == 4);
  ASSERT(antestatal_static_i32_ptr-> == 4);
  ASSERT(antestatal_static_proc(4, 5) == 9);
  // TODO: Add a negative constexpr test that verifies mutating an antestatal static is rejected.

}


::templated_holder TEMPLATE(TYPE AUTO(t)) CLASS
{
  .value VAR t;
}

::templated_holder_value_test STATIC_TEST
{
  VAR holder templated_holder#( I32 );
  holder.value := 5;
  ASSERT(holder.value == 5);

  holder.value := 9;

  ASSERT(holder.value == 9);
}

::value_template_holder TEMPLATE(@count:value_count VALUE U64) CLASS
{
  .stored VAR U64;

  .fill FUNCTION(): U64
  {
    VAR values [value_count]U64;
    VAR local U64 := value_count;
    values[0] := local;
    values[1] := local + 1;
    .stored := value_count;
    RETURN values[1];
  }
}

::value_template_argument_test STATIC_TEST
{
  VAR holder value_template_holder#(@count 4);
  ASSERT(holder.fill() == 5);
  ASSERT(holder.stored == 4);
}

::postincrement_array_iterator_store_test STATIC_TEST
{

  VAR x [3]I32;

  VAR y =>> I32;
  y := x[& 0];

  (y++)-> := 10;
  (y++)-> := 20;
  (y++)-> := 30;

  ASSERT( x[0] == 10 );
  ASSERT( x[1] == 20 );
  ASSERT( x[2] == 30 );
}

::array_byte_pointer_load_store_test STATIC_TEST
{
  VAR x [4]BYTE;

  VAR z =>> BYTE;

  z := x[& 0];

  VAR z2 =>> BYTE;
  z2 := z;

  z-> := 42;

  ASSERT( x[0] == 42 );

  z2-> := 84;

  ASSERT( x[0] == 84 );
}


::static_choose_import_test STATIC_TEST
{
   VAR x I32;

   x := STATIC_CHOOSE( foolib::imported_function() == 42 , 10 , 20 );
   ASSERT( x == 10 );

   x := STATIC_CHOOSE( foolib::imported_function() != 42 , 10 , 20 );
   ASSERT( x == 20 );
}

::static_counter_probe FUNCTION(@counter MUT& I32, @value BOOL) : BOOL
{
   counter++;
   RETURN value;
}

::static_var_loop_expansion_test STATIC_TEST
{
   VAR foo I32 := 0;
   STATIC_VAR x I32 := 1;
   STATIC_WHILE (x < 5) {
      foo++;
      STATIC_EVAL x++;
   }
   ASSERT(foo == 4);
}

::static_if_selected_branch_test STATIC_TEST
{
   STATIC_VAR x I32 := 0;
   STATIC_IF (FALSE) {
      STATIC_EVAL x := 99;
   } STATIC_ELSE {
      STATIC_EVAL x++;
   }
   VAR y I32 := SNAPSHOT(x);
   ASSERT(y == 1);
}

::static_if_condition_mutation_test STATIC_TEST
{
   STATIC_VAR x I32 := 0;
   STATIC_IF (static_counter_probe(@counter x, @value TRUE)) {
      STATIC_EVAL x++;
   } STATIC_ELSE {
      STATIC_EVAL x := 99;
   }
   VAR y I32 := SNAPSHOT(x);
   ASSERT(y == 2);
}

::static_default_and_call_initializers_test STATIC_TEST
{
   STATIC x I32;
   STATIC y I32 :(@OTHER 7);
   ASSERT(x == 0);
   ASSERT(y == 7);
}

::static_snapshot_read_after_mutation_test STATIC_TEST
{
   STATIC_VAR x I32 := 1;
   VAR before I32 := SNAPSHOT(x);
   STATIC_EVAL x++;
   VAR after I32 := SNAPSHOT(x);
   ASSERT(before == 1);
   ASSERT(after == 2);
}

::runtime_if_static_generation_order_test STATIC_TEST
{
   STATIC_VAR x I32 := 0;
   IF (TRUE) {
      STATIC_EVAL x++;
   } ELSE {
      STATIC_EVAL x++;
   }
   VAR y I32 := SNAPSHOT(x);
   ASSERT(y == 2);
}

::runtime_while_static_generation_once_test STATIC_TEST
{
   STATIC_VAR x I32 := 0;
   VAR i I32 := 0;
   WHILE (i < 2) {
      STATIC_EVAL x++;
      i++;
   }
   VAR y I32 := SNAPSHOT(x);
   ASSERT(y == 1);
}

::runtime_for_loop_test STATIC_TEST
{
   VAR sum I32 := 0;
   FOR INIT { VAR i I32 := 0; } TEST(i < 5) STEP { i++; } LOOP {
      sum := sum + i;
   };
   ASSERT(sum == 10);
}

::runtime_for_posttest_loop_test STATIC_TEST
{
   VAR count I32 := 0;
   VAR i I32 := 0;
   FOR POSTTEST(i < 3) STEP { i++; } LOOP {
      count++;
   };
   ASSERT(count == 4);
}

::static_constant_mutation_fails_test STATIC_TEST EXPECT_COMPILATION_FAILURE
{
   STATIC x I32 := 0;
   STATIC_EVAL x++;
}

::static_choose_readonly_static_view_test STATIC_TEST EXPECT_COMPILATION_FAILURE
{
   STATIC_VAR x I32 := 0;
   VAR y I32 := STATIC_CHOOSE(static_counter_probe(@counter x, @value TRUE), 1, 2);
}

::static_var_regular_var_snapshots_from_address_test STATIC_TEST
{
   // This test verifies that when a STATIC_VAR is captured at runtime, the complete
   // state of static values is snapshotted and that subsequent mutations to the static
   // value do not affect the captured snapshot.
   // It also tests that at each snapshot capture, the pointers to static variables
   // are updated to point to the current value of the static variable.

   STATIC_VAR x I32 := 0;
   STATIC_VAR x_ptr CONST->I32 := x<-;

   VAR y CONST->I32 := SNAPSHOT(x)<-;
   STATIC_EVAL x++;
   VAR z CONST->I32 := SNAPSHOT(x_ptr);

   STATIC_EVAL x++;

   ASSERT(SNAPSHOT(x) == 2);
   ASSERT(y-> == 0);
   ASSERT(z-> == 1);
}

::static_var_runtime_access_without_snapshot_fails_test STATIC_TEST EXPECT_COMPILATION_FAILURE
{
   STATIC_VAR x I32 := 0;
   VAR y I32 := x;
}

::static_snapshot_expression_does_not_authorize_later_access_test STATIC_TEST EXPECT_COMPILATION_FAILURE
{
   STATIC_VAR x I32 := 0;
   SNAPSHOT(x);
   VAR y I32 := x;
}

::static_var_runtime_access_with_snapshot_test STATIC_TEST
{
   STATIC_VAR x I32 := 3;
   VAR y I32 := SNAPSHOT(x);
   ASSERT(y == 3);
}

::static_const_pointer_to_mutable_without_snapshot_fails_test STATIC_TEST EXPECT_COMPILATION_FAILURE
{
   STATIC_VAR x I32 := 4;
   STATIC ptr CONST->I32 := x<-;
   VAR y CONST->I32 := ptr;
}

::static_const_pointer_to_mutable_with_snapshot_test STATIC_TEST
{
   STATIC_VAR x I32 := 4;
   STATIC ptr CONST->I32 := x<-;
   VAR y CONST->I32 := SNAPSHOT(ptr);
   ASSERT(y-> == 4);
}
