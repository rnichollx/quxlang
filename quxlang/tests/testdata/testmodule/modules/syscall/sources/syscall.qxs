LANGUAGE QUXLANG EN 0.0;


::linux INCLUDE_IF(OS_LINUX) NAMESPACE
{
  ::write INCLUDE_IF(ARCH_X64) ASM_PROCEDURE X64
    CALLABLE CALLCONV CCALL(I32, CONST =>> BYTE, SZ; RETURN SZ)
  {
    MOV RAX, 1
    SYSCALL
    RET
  }

  ::write INCLUDE_IF(ARCH_X86) ASM_PROCEDURE X64
    CALLABLE CALLCONV CCALL(I32, CONST =>> BYTE, SZ; RETURN SZ)
  {
    MOV EBX, [ESP+4]
    MOV ECX, [ESP+8]
    MOV EDX, [ESP+12]
    MOV EAX, 4
    INT 0x80
    RET
  }

  ::write INCLUDE_IF(ARCH_ARM64) ASM_PROCEDURE ARM
    CALLABLE CALLCONV CCALL(I32, CONST =>> BYTE, SZ; RETURN SZ)
  {
    MOV X8, 64
    SVC 0
    RET
  }

  ::exit INCLUDE_IF(ARCH_X64) ASM_PROCEDURE X64
    CALLABLE(I32; RETURN I32)
  {
    MOV RAX, 60
    SYSCALL
    RET
  }

  ::exit INCLUDE_IF(ARCH_X86) ASM_PROCEDURE X64
    CALLABLE(I32; RETURN I32)
  {
    MOV EBX, [ESP+4]
    MOV EAX, 1
    INT 0x80
    RET
  }

  ::exit INCLUDE_IF(ARCH_ARM64) ASM_PROCEDURE ARM
    CALLABLE(I32; RETURN I32)
  {
    MOV X8, 93
    SVC 0
    RET
  }

  ::mmap_anonymous_private INCLUDE_IF(ARCH_X64) ASM_PROCEDURE X64
    CALLABLE CALLCONV CCALL(SZ; RETURN =>>VOID)
  {
    MOV RSI, RDI
    XOR RDI, RDI
    MOV RDX, 3
    MOV R10, 34
    MOV R8, -1
    XOR R9, R9
    MOV RAX, 9
    SYSCALL
    RET
  }

  ::mmap_anonymous_private INCLUDE_IF(ARCH_X86) ASM_PROCEDURE X64
    CALLABLE CALLCONV CCALL(SZ; RETURN =>>VOID)
  {
    PUSH EBP
    MOV ECX, [ESP+8]
    XOR EBX, EBX
    MOV EDX, 3
    MOV ESI, 34
    MOV EDI, -1
    XOR EBP, EBP
    MOV EAX, 192
    INT 0x80
    POP EBP
    RET
  }

  ::mmap_anonymous_private INCLUDE_IF(ARCH_ARM64) ASM_PROCEDURE ARM
    CALLABLE CALLCONV CCALL(SZ; RETURN =>>VOID)
  {
    MOV X1, X0
    MOV X0, 0
    MOV X2, 3
    MOV X3, 34
    MOV X4, -1
    MOV X5, 0
    MOV X8, 222
    SVC 0
    RET
  }

  ::futex_wait INCLUDE_IF(ARCH_X64) ASM_PROCEDURE X64
    CALLABLE CALLCONV CCALL(MUT& ATOMIC#I32, I32; RETURN I32)
  {
    MOV RDX, RSI
    MOV RSI, 0
    XOR R10, R10
    XOR R8, R8
    XOR R9, R9
    MOV RAX, 202
    SYSCALL
    RET
  }

  ::futex_wait INCLUDE_IF(ARCH_X86) ASM_PROCEDURE X64
    CALLABLE CALLCONV CCALL(MUT& ATOMIC#I32, I32; RETURN I32)
  {
    PUSH EBP
    MOV EBX, [ESP+8]
    MOV ECX, 0
    MOV EDX, [ESP+12]
    XOR ESI, ESI
    XOR EDI, EDI
    XOR EBP, EBP
    MOV EAX, 240
    INT 0x80
    POP EBP
    RET
  }

  ::futex_wait INCLUDE_IF(ARCH_ARM64) ASM_PROCEDURE ARM
    CALLABLE CALLCONV CCALL(MUT& ATOMIC#I32, I32; RETURN I32)
  {
    MOV X2, X1
    MOV X1, 0
    MOV X3, 0
    MOV X4, 0
    MOV X5, 0
    MOV X8, 98
    SVC 0
    RET
  }

  ::futex_wake INCLUDE_IF(ARCH_X64) ASM_PROCEDURE X64
    CALLABLE CALLCONV CCALL(MUT& ATOMIC#I32, I32; RETURN I32)
  {
    MOV RDX, RSI
    MOV RSI, 1
    XOR R10, R10
    XOR R8, R8
    XOR R9, R9
    MOV RAX, 202
    SYSCALL
    RET
  }

  ::futex_wake INCLUDE_IF(ARCH_X86) ASM_PROCEDURE X64
    CALLABLE CALLCONV CCALL(MUT& ATOMIC#I32, I32; RETURN I32)
  {
    PUSH EBP
    MOV EBX, [ESP+8]
    MOV ECX, 1
    MOV EDX, [ESP+12]
    XOR ESI, ESI
    XOR EDI, EDI
    XOR EBP, EBP
    MOV EAX, 240
    INT 0x80
    POP EBP
    RET
  }

  ::futex_wake INCLUDE_IF(ARCH_ARM64) ASM_PROCEDURE ARM
    CALLABLE CALLCONV CCALL(MUT& ATOMIC#I32, I32; RETURN I32)
  {
    MOV X2, X1
    MOV X1, 1
    MOV X3, 0
    MOV X4, 0
    MOV X5, 0
    MOV X8, 98
    SVC 0
    RET
  }
}
