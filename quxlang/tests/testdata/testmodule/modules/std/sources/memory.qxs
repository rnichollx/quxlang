LANGUAGE QUXLANG EN 0.0;

IMPORT syscall;


::memory_bucket_size DOC <$
  The `memory_bucket_size` function is intended to be used to group free-list allocations by useful sizes.
  $>
  FUNCTION(@size SZ): SZ
{
  VAR bucket SZ := 8;
  VAR step SZ := 8;

  WHILE (bucket < size)
  {
    bucket += step;
    IF (bucket == step * 4)
    {
      step *= 2;
    }
  }

  RETURN bucket;
}

::memory_region_size FUNCTION(@size SZ): SZ
{
  VAR region_size SZ := 4096;

  WHILE (region_size < size)
  {
    region_size += 4096;
  }

  RETURN region_size;
}

::mutex CLASS
{
  .state VAR ATOMIC#I32;

  .lock FUNCTION()
  {
    WHILE (TRUE)
    {
      VAR expected I32 := 0;
      IF (.state.COMPARE_EXCHANGE#(@SUCCESS ATOMIC_ACQREL, @FAILURE ATOMIC_ACQUIRE)(expected, 1))
      {
        RETURN;
      }

      WHILE (.state.LOAD#ATOMIC_ACQUIRE() != 0)
      {
        syscall::linux::futex_wait(.state<-, 1);
      }
    }
  }

  .unlock FUNCTION()
  {
    .state.STORE#ATOMIC_RELEASE(0);
    syscall::linux::futex_wake(.state<-, 1);
  }
}

::default_allocator CLASS
// This allocator is mostly AI generated so avoid using it as an example of how to write an allocator.
{
  ::alloc_root_for TEMPLATE(@size VALUE SZ, @align VALUE SZ) VAR alloc_root;

  ::alloc_root CLASS
  {
    .mtx VAR mutex;
    .free_list VAR =>>VOID;
    .new_free_region VAR =>>VOID;
    .new_free_bytes VAR SZ;
  }


  ::allocate TEMPLATE(@size VALUE SZ, @align VALUE SZ) FUNCTION(): =>>VOID
  {
     RETURN alloc_bytes#(@size size, @align align)(@count 1);
  }

  ::dealloc TEMPLATE(@size VALUE SZ, @align VALUE SZ) FUNCTION(@ptr =>>VOID)
  {
     dealloc_bytes#(@size size, @align align)(@ptr ptr, @count 1);
  }

  ::alloc_multiple TEMPLATE(@T TYPE AUTO(t)) FUNCTION(@count SZ): =>>STORAGE(t)
  {
     VAR result =>>STORAGE(t);
     RUNTIME CONSTEXPR
     {
       result := CONSTEXPR_ALLOC_MULTIPLE#t(count);
     }
     ELSE
     {
       result := alloc_bytes#(@size SIZEOF(t), @align SIZEOF(t))(@count count) AS REINTERPRET =>>STORAGE(t);
     }

     RETURN result;
  }


  ::dealloc_multiple TEMPLATE(@T TYPE AUTO(t)) FUNCTION(@ptr AUTO(ptr_type), @count SZ)
  {
     RUNTIME NATIVE
     {
       dealloc_bytes#(@size SIZEOF(t), @align SIZEOF(t))(@ptr ptr AS REINTERPRET =>>VOID, @count count);
     }
     ELSE
     {
     }
  }

  ::alloc_bytes TEMPLATE(@size VALUE SZ, @align VALUE SZ) FUNCTION(@count SZ): =>>VOID
  {
     VAR selected_size SZ := memory_bucket_size(@size size);
     VAR selected_align SZ := memory_bucket_size(@size align);
     VAR free_node_data_size SZ := SIZEOF(=>>VOID);
     free_node_data_size += SIZEOF(SZ);
     VAR free_node_size SZ := memory_bucket_size(@size free_node_data_size);
     IF (selected_size < selected_align)
     {
       selected_size := selected_align;
     }
     IF (selected_size < free_node_size)
     {
       selected_size := free_node_size;
     }
     VAR selected_bytes SZ := selected_size * count;
     VAR selected_alloc &alloc_root := alloc_root_for#(@size memory_bucket_size(@size size), @align memory_bucket_size(@size align));

     selected_alloc.mtx.lock();

     VAR previous_free_node =>>VOID;
     VAR current_free_node =>>VOID := selected_alloc.free_list;
     WHILE (current_free_node??)
     {
       VAR current_next =>> =>>VOID := current_free_node AS REINTERPRET =>> =>>VOID;
       VAR current_bytes_void =>>VOID := ((current_free_node AS REINTERPRET =>>BYTE) + SIZEOF(=>>VOID)) AS REINTERPRET =>>VOID;
       VAR current_bytes =>>SZ := current_bytes_void AS REINTERPRET =>>SZ;
       IF (current_bytes-> >= selected_bytes)
       {
         IF (previous_free_node??)
         {
           VAR previous_next =>> =>>VOID := previous_free_node AS REINTERPRET =>> =>>VOID;
           previous_next-> := current_next->;
         }
         ELSE
         {
           selected_alloc.free_list := current_next->;
         }
         selected_alloc.mtx.unlock();
         RETURN current_free_node;
       }

       previous_free_node := current_free_node;
       current_free_node := current_next->;
     }

     IF (selected_alloc.new_free_bytes < selected_bytes)
     {
       VAR region_size SZ := memory_region_size(@size selected_bytes);
       selected_alloc.new_free_region := syscall::linux::mmap_anonymous_private(region_size);
       selected_alloc.new_free_bytes := region_size;
     }

     VAR new_allocation =>>VOID := selected_alloc.new_free_region;
     selected_alloc.new_free_region := ((selected_alloc.new_free_region AS REINTERPRET =>>BYTE) + selected_bytes) AS REINTERPRET =>>VOID;
     selected_alloc.new_free_bytes -= selected_bytes;
     selected_alloc.mtx.unlock();

     RETURN new_allocation;
  }

  ::dealloc_bytes TEMPLATE(@size VALUE SZ, @align VALUE SZ) FUNCTION(@ptr =>>VOID, @count SZ)
  {
     IF ((ptr??) == FALSE || count == 0)
     {
       RETURN;
     }

     VAR selected_size SZ := memory_bucket_size(@size size);
     VAR selected_align SZ := memory_bucket_size(@size align);
     VAR free_node_data_size SZ := SIZEOF(=>>VOID);
     free_node_data_size += SIZEOF(SZ);
     VAR free_node_size SZ := memory_bucket_size(@size free_node_data_size);
     IF (selected_size < selected_align)
     {
       selected_size := selected_align;
     }
     IF (selected_size < free_node_size)
     {
       selected_size := free_node_size;
     }
     VAR selected_bytes SZ := selected_size * count;
     VAR selected_alloc &alloc_root := alloc_root_for#(@size memory_bucket_size(@size size), @align memory_bucket_size(@size align));

     selected_alloc.mtx.lock();
     VAR free_node =>> =>>VOID := ptr AS REINTERPRET =>> =>>VOID;
     VAR free_node_bytes_void =>>VOID := ((ptr AS REINTERPRET =>>BYTE) + SIZEOF(=>>VOID)) AS REINTERPRET =>>VOID;
     VAR free_node_bytes =>>SZ := free_node_bytes_void AS REINTERPRET =>>SZ;
     free_node-> := selected_alloc.free_list;
     free_node_bytes-> := selected_bytes;
     selected_alloc.free_list := ptr;
     selected_alloc.mtx.unlock();
  }
}
