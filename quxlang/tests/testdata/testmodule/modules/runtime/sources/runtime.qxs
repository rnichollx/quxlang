LANGUAGE QUXLANG EN 0.0;

IMPORT std;

::stdout STATIC I32 := 1;

::write_bytes FUNCTION(@fd I32, @begin CONST =>> BYTE, @end CONST =>> BYTE)
{
  linux::syscall::write(fd, begin, end - begin AS ASSUME SZ);
}

::write FUNCTION(@fd I32, @msg STRING_CONSTANT)
{
  write_bytes(@fd fd, @begin msg.BEGIN(), @end msg.END());
}

::exit FUNCTION(@code I32)
{
  STATIC_IF(OS_LINUX)
  {
    linux::syscall::exit(code);
  }
}

::ASSERT_FAIL FUNCTION(@expr STRING_CONSTANT, @file SZ, @line SZ, @column SZ, @tag CONST -> STRING_CONSTANT)
{
  IF (active_test.BEGIN()??)
  {
     write(@fd stdout, @msg "FAILED: ");
     write(@fd stdout, @msg active_test);
     write(@fd stdout, @msg "\n");
  }
  write(@msg "Assert failed: ", @fd stdout);
  write(@fd stdout, @msg expr);
  write(@msg "\n", @fd stdout);
  exit(@code 1);
}

::INITGUARD_TRY_ACQUIRE FUNCTION(@guard MUT& INITGUARD): BOOL
{
  WHILE (TRUE)
  {
    VAR state UINTPTR := guard.LOAD#ATOMIC_ACQUIRE();
    IF (state == 2)
    {
      RETURN FALSE;
    }
    IF (state == 0)
    {
      VAR expected UINTPTR := 0;
      IF (guard.COMPARE_EXCHANGE#(@SUCCESS ATOMIC_ACQREL, @FAILURE ATOMIC_ACQUIRE)(expected, 1))
      {
        RETURN TRUE;
      }
    }
    ELSE IF (state != 1)
    {
      ASSERT(FALSE, "Invalid initguard state");
    }
  }
}

::INITGUARD_COMPLETE FUNCTION(@guard MUT& INITGUARD)
{
  guard.STORE#ATOMIC_RELEASE(2);
}

::INITGUARD_ABORT FUNCTION(@guard MUT& INITGUARD)
{
  guard.STORE#ATOMIC_RELEASE(0);
}

::linux INCLUDE_IF(OS_LINUX) NAMESPACE
{
  ::syscall NAMESPACE
  {
    ::write INCLUDE_IF(ARCH_X64) ASM_PROCEDURE X64
      CALLABLE CALLCONV CCALL(I32, CONST =>> BYTE, SZ; RETURN SZ)
    {
      MOV RAX, 1
      SYSCALL
      RET
    }

    ::write INCLUDE_IF(ARCH_X86) ASM_PROCEDURE X64
      CALLABLE CALLCONV CCALL(I32, CONST =>> BYTE, SZ; RETURN SZ)
    {
      MOV EBX, [ESP+4]
      MOV ECX, [ESP+8]
      MOV EDX, [ESP+12]
      MOV EAX, 4
      INT 0x80
      RET
    }

    ::write INCLUDE_IF(ARCH_ARM64) ASM_PROCEDURE ARM
      CALLABLE CALLCONV CCALL(I32, CONST =>> BYTE, SZ; RETURN SZ)
    {
      MOV X8, 64
      SVC 0
      RET
    }

    ::exit INCLUDE_IF(ARCH_X64) ASM_PROCEDURE X64
      CALLABLE(I32; RETURN I32)
    {
      MOV RAX, 60
      SYSCALL
      RET
    }

    ::exit INCLUDE_IF(ARCH_X86) ASM_PROCEDURE X64
      CALLABLE(I32; RETURN I32)
    {
      MOV EBX, [ESP+4]
      MOV EAX, 1
      INT 0x80
      RET
    }

    ::exit INCLUDE_IF(ARCH_ARM64) ASM_PROCEDURE ARM
      CALLABLE(I32; RETURN I32)
    {
      MOV X8, 93
      SVC 0
      RET
    }
  }
}

::PROGRAM_START INCLUDE_IF(OS_LINUX && ARCH_X64) ASM_PROCEDURE X64
{
  MOVABS RAX, OFFSET OBJECT_REF(MAIN_FUNCTION)
  MOV RAX, [RAX]
  CALL RAX
  MOV RDI, RAX
  MOV RAX, 60
  SYSCALL
}

::PROGRAM_START INCLUDE_IF(OS_LINUX && ARCH_X86) ASM_PROCEDURE X64
{
  MOV EAX, OFFSET OBJECT_REF(MAIN_FUNCTION)
  MOV EAX, [EAX]
  CALL EAX
  MOV EBX, EAX
  MOV EAX, 1
  INT 0x80
}

::PROGRAM_START INCLUDE_IF(OS_LINUX && ARCH_ARM64) ASM_PROCEDURE ARM
{
  ADRP X16, :got:OBJECT_REF(MAIN_FUNCTION)
  LDR X16, [X16, :got_lo12:OBJECT_REF(MAIN_FUNCTION)]
  LDR X16, [X16]
  BLR X16
  MOV X8, 93
  SVC 0
}

::active_test VAR STRING_CONSTANT;

::unit_testing_program_main FUNCTION(%count SZ, %names CONST=>> STRING_CONSTANT, %procs CONST=>> PROCEDURE())
{
  VAR i SZ := 0;
  WHILE (i < count)
  {
    active_test := names[i];
    write(@fd stdout, @msg "Testing: ");
    write(@fd stdout, @msg active_test);
    write(@fd stdout, @msg "\n");
    procs[i]();
    write(@fd stdout, @msg "PASSED: ");
    write(@fd stdout, @msg names[i]);
    write(@fd stdout, @msg "\n");
    i++;
  }
}

::UNIT_TESTING_PROGRAM_START INCLUDE_IF(OS_LINUX && ARCH_X64) ASM_PROCEDURE X64
{
  MOVABS RDI, OFFSET OBJECT_REF(UNIT_TEST_COUNT)
  MOV RDI, [RDI]
  MOVABS RSI, OFFSET OBJECT_REF(UNIT_TEST_NAMES)
  MOV RSI, [RSI]
  MOVABS RDX, OFFSET OBJECT_REF(UNIT_TEST_PROC)
  MOV RDX, [RDX]
  MOVABS RAX, OFFSET PROCEDURE_REF("", unit_testing_program_main#[0])
  CALL RAX
  MOV RDI, 0
  MOV RAX, 60
  SYSCALL
}
