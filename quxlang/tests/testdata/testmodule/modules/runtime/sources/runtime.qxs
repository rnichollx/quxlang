LANGUAGE QUXLANG EN 0.0;

IMPORT syscall;

::stdout STATIC I32 := 1;

::write_bytes FUNCTION(@fd I32, @begin CONST =>> BYTE, @end CONST =>> BYTE)
{
  syscall::linux::write(@fd fd, @buffer begin, @count end - begin AS ASSUME SZ);
}

::write FUNCTION(@fd I32, @msg STRING_CONSTANT)
{
  write_bytes(@fd fd, @begin msg.BEGIN(), @end msg.END());
}

::write_decimal FUNCTION(@fd I32, @value SZ)
{
  VAR digits [20]BYTE;
  VAR remaining SZ := value;
  VAR digit_count SZ := 0;

  IF (remaining == 0)
  {
    digits[19] := 48;
    write_bytes(@fd fd, @begin digits[& 19], @end digits[& 20]);
    RETURN;
  }

  WHILE (remaining != 0)
  {
    digit_count++;
    VAR digit BYTE := (((remaining % 10) + 48) AS PARTIAL U8) AS BYTE;
    digits[20 - digit_count] := digit;
    remaining := remaining / 10;
  }

  write_bytes(@fd fd, @begin digits[& (20 - digit_count)], @end digits[& 20]);
}

::exit FUNCTION(@code I32)
{
  STATIC_IF(OS_LINUX)
  {
    syscall::linux::exit(@code code);
  }
}

::ASSERT_FAIL FUNCTION(@expr STRING_CONSTANT, @file SZ, @line SZ, @column SZ, @tag CONST -> STRING_CONSTANT)
{
  IF (active_test.BEGIN()??)
  {
     write(@fd stdout, @msg "FAILED: ");
     write(@fd stdout, @msg active_test);
     write(@fd stdout, @msg "\n");
  }
  write(@msg "Assert failed: ", @fd stdout);
  write(@fd stdout, @msg expr);
  write(@msg "\n", @fd stdout);
  exit(@code 1);
}

::PANIC FUNCTION(@message STRING_CONSTANT, @file SZ, @line SZ, @column SZ)
{
  write(@fd stdout, @msg "Panic: ");
  write(@fd stdout, @msg message);
  write(@fd stdout, @msg "\n");
  exit(@code 1);
}

::INITGUARD_TRY_ACQUIRE FUNCTION(@guard MUT& INITGUARD): BOOL
{
  WHILE (TRUE)
  {
    VAR state UINTPTR := guard.LOAD#ATOMIC_ACQUIRE();
    IF (state == 2)
    {
      RETURN FALSE;
    }
    IF (state == 0)
    {
      VAR expected UINTPTR := 0;
      IF (guard.COMPARE_EXCHANGE#(@SUCCESS ATOMIC_ACQREL, @FAILURE ATOMIC_ACQUIRE)(expected, 1))
      {
        RETURN TRUE;
      }
    }
    ELSE IF (state != 1)
    {
      ASSERT(FALSE, "Invalid initguard state");
    }
  }
}

::INITGUARD_COMPLETE FUNCTION(@guard MUT& INITGUARD)
{
  guard.STORE#ATOMIC_RELEASE(2);
}

::INITGUARD_ABORT FUNCTION(@guard MUT& INITGUARD)
{
  guard.STORE#ATOMIC_RELEASE(0);
}

::PROGRAM_START INCLUDE_IF(OS_LINUX) ASM_PROCEDURE X64
{
  MOV RDI, RSP
  MOVABS RAX, OFFSET PROCEDURE_REF("", linux_parse_initial_stack#[0])
  CALL RAX
  MOVABS RAX, OFFSET OBJECT_REF(MAIN_FUNCTION)
  MOV RAX, [RAX]
  CALL RAX
  MOV RDI, RAX
  MOV RAX, 60
  SYSCALL
}

::PROGRAM_START INCLUDE_IF(OS_LINUX) ASM_PROCEDURE X86
{
  MOV ECX, ESP
  PUSH ECX
  MOV EAX, OFFSET PROCEDURE_REF("", linux_parse_initial_stack#[0])
  CALL EAX
  ADD ESP, 4
  MOV EAX, OFFSET OBJECT_REF(MAIN_FUNCTION)
  MOV EAX, [EAX]
  CALL EAX
  MOV EBX, EAX
  MOV EAX, 1
  INT 0x80
}

::PROGRAM_START INCLUDE_IF(OS_LINUX) ASM_PROCEDURE ARM64
{
  MOV X0, SP
  LDR X16, PROCEDURE_REF("", linux_parse_initial_stack#[0])
  BLR X16
  ADRP X16, :got:OBJECT_REF(MAIN_FUNCTION)
  LDR X16, [X16, :got_lo12:OBJECT_REF(MAIN_FUNCTION)]
  LDR X16, [X16]
  BLR X16
  MOV X8, 93
  SVC 0
}

::active_test VAR STRING_CONSTANT;

::unit_testing_program_main FUNCTION(%count SZ, %names CONST=>> STRING_CONSTANT, %procs CONST=>> PROCEDURE())
{
  VAR i SZ := 0;
  WHILE (i < count)
  {
    active_test := names[i];
    write(@fd stdout, @msg "Testing: ");
    write(@fd stdout, @msg active_test);
    write(@fd stdout, @msg "\n");
    procs[i]();
    write(@fd stdout, @msg "PASSED: ");
    write(@fd stdout, @msg names[i]);
    write(@fd stdout, @msg "\n");
    i++;
  }
  write(@fd stdout, @msg "All ");
  write_decimal(@fd stdout, @value count);
  write(@fd stdout, @msg " unit tests passed\n");
}

::UNIT_TESTING_PROGRAM_START INCLUDE_IF(OS_LINUX) ASM_PROCEDURE X64
{
  MOV RDI, RSP
  MOVABS RAX, OFFSET PROCEDURE_REF("", linux_parse_initial_stack#[0])
  CALL RAX
  MOVABS RDI, OFFSET OBJECT_REF(UNIT_TEST_COUNT)
  MOV RDI, [RDI]
  MOVABS RSI, OFFSET OBJECT_REF(UNIT_TEST_NAMES)
  MOV RSI, [RSI]
  MOVABS RDX, OFFSET OBJECT_REF(UNIT_TEST_PROC)
  MOV RDX, [RDX]
  MOVABS RAX, OFFSET PROCEDURE_REF("", unit_testing_program_main#[0])
  CALL RAX
  MOV RDI, 0
  MOV RAX, 60
  SYSCALL
}
