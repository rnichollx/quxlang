LANGUAGE QUXLANG EN 0.0;

::arrytest_cls CLASS
{
  .val VAR I32;

  .CONSTRUCTOR FUNCTION()
  {
     .val := 5;
  }

}

::array_default_constructor_test STATIC_TEST

{
    VAR x [3]arrytest_cls;

    ASSERT( x[0].val == 5 );
    ASSERT( x[1].val == 5 );
    ASSERT( x[2].val == 5 );
}

::array_default_constructor_test_unit_test UNIT_TEST
{
    VAR x [3]arrytest_cls;

    ASSERT( x[0].val == 5 );
    ASSERT( x[1].val == 5 );
    ASSERT( x[2].val == 5 );
}

::array_positional_element_cls CLASS
{
  .val VAR I32;

  .CONSTRUCTOR FUNCTION(@OTHER I32)
  {
     .val := OTHER;
  }
}

::array_positional_constructor_test STATIC_TEST
{
    VAR x [3]I32 :(1, 2, 3);

    ASSERT( x[0] == 1 );
    ASSERT( x[1] == 2 );
    ASSERT( x[2] == 3 );

    VAR y [2]array_positional_element_cls :(4, 7);
    ASSERT( y[0].val == 4 );
    ASSERT( y[1].val == 7 );
}

::array_positional_constructor_test_unit_test UNIT_TEST
{
    VAR x [3]I32 :(1, 2, 3);

    ASSERT( x[0] == 1 );
    ASSERT( x[1] == 2 );
    ASSERT( x[2] == 3 );

    VAR y [2]array_positional_element_cls :(4, 7);
    ASSERT( y[0].val == 4 );
    ASSERT( y[1].val == 7 );
}

::array_zero_length_positional_default_test STATIC_TEST
{
    VAR x [0]I32 :();
}

::array_zero_length_positional_default_test_unit_test UNIT_TEST
{
    VAR x [0]I32 :();
}

::array_positional_too_many_test STATIC_TEST EXPECT_COMPILATION_FAILURE
{
    VAR x [2]I32 :(1, 2, 3);
}

::array_positional_too_few_test STATIC_TEST EXPECT_COMPILATION_FAILURE
{
    VAR x [3]I32 :(1, 2);
}

::array_literal_helper FUNCTION() {
   UNIMPLEMENTED;

   // VAR x [4]I32 :[ 1, 3, 5, 7 ];

   ASSERT( x[0] == 1 );
   ASSERT( x[1] == 3 );
   ASSERT( x[2] == 5 );
   ASSERT( x[3] == 7 );

}


::runtime_statement_branching_test STATIC_TEST
{

   VAR x I32;

   RUNTIME CONSTEXPR {
      x := 10;
   } ELSE {
      x := 20;
   }
   ASSERT( x == 10 );

   RUNTIME NATIVE {
      x := 30;
   } ELSE {
      x := 40;
   }

   ASSERT( x == 40 );

}

::runtime_statement_branching_test_unit_test UNIT_TEST
{

   VAR x I32;

   RUNTIME CONSTEXPR {
      x := 10;
   } ELSE {
      x := 20;
   }
   ASSERT( x == 20 );

   RUNTIME NATIVE {
      x := 30;
   } ELSE {
      x := 40;
   }

   ASSERT( x == 30 );

}




::foo FUNCTION(%a I32, %b I32): I32
{
  RETURN a + b;
}

::foo_error FUNCTION(%a I32, %b I32): I32
{
  RETURN a + b; // + not_defined(@z 1);
}

::bar FUNCTION(%a I32, %b I32): I32
{
  RETURN a * b;
}

::option_num OPTION NUMBER DEFAULT(42);

::option_test STATIC_TEST
{
  ASSERT(option_num == 5);
}

::option_test_unit_test UNIT_TEST
{
  ASSERT(option_num == 5);
}


::buz CLASS
{
  .x VAR I32;

  .CONSTRUCTOR FUNCTION()
  {
     .x := 9;
  }

  .DESTRUCTOR FUNCTION()
  {

  }

  .foo FUNCTION()
  {
    .x := .x + 1;
  }
}

::storage_buz_helper FUNCTION(): I32
{
  VAR slot STORAGE(buz);
  VAR p ->buz := PLACE AT(slot) buz;
  ASSERT(p??);
  ASSERT(buz_x(PUN slot AS buz) == 9);
  buz_inc(PUN slot AS buz);
  ASSERT(buz_x(PUN slot AS buz) == 10);
  DESTROY AT(slot) buz;

  VAR slot2 STORAGE(I32);
  VAR iptr ->I32 := PLACE AT(slot2) I32 := 9;
  ASSERT(iptr??);
  ASSERT((PUN slot2 AS I32) == 9);
  DESTROY AT(slot2) I32;
  RETURN 10;
}

::storage_buz_lifetime_test STATIC_TEST
{
  ASSERT(storage_buz_helper() == 10);
}

::storage_buz_lifetime_test_unit_test UNIT_TEST
{
  ASSERT(storage_buz_helper() == 10);
}

::constexpr_alloc_i32_helper FUNCTION(): I32
{
  VAR slot_ptr -> STORAGE(I32) := CONSTEXPR_ALLOC#I32();
  VAR placed_ptr ->I32 := PLACE AT(slot_ptr->) I32 := 123;
  ASSERT(placed_ptr??);
  ASSERT((PUN (slot_ptr->) AS I32) == 123);
  DESTROY AT(slot_ptr->) I32;
  CONSTEXPR_DEALLOC#I32(slot_ptr);
  RETURN 123;
}

::constexpr_alloc_i32_test STATIC_TEST
{
  ASSERT(constexpr_alloc_i32_helper() == 123);
}

::constexpr_alloc_buz_helper FUNCTION(): I32
{
  VAR slot_ptr -> STORAGE(buz) := CONSTEXPR_ALLOC#buz();
  VAR placed_ptr ->buz := PLACE AT(slot_ptr->) buz;
  ASSERT(placed_ptr??);
  ASSERT(buz_x(PUN (slot_ptr->) AS buz) == 9);
  DESTROY AT(slot_ptr->) buz;
  CONSTEXPR_DEALLOC#buz(slot_ptr);
  RETURN 9;
}

::constexpr_alloc_buz_test STATIC_TEST
{
  ASSERT(constexpr_alloc_buz_helper() == 9);
}

::constexpr_multialloc_helper FUNCTION(): I32
{
  VAR count SZ := 3;
  VAR slots =>> STORAGE(BYTE) := CONSTEXPR_ALLOC_MULTIPLE#BYTE(count);
  VAR first ->BYTE := PLACE AT(slots->) BYTE := 7;
  VAR second ->BYTE := PLACE AT((slots + 1)->) BYTE := 9;
  VAR third ->BYTE := PLACE AT((slots + 2)->) BYTE := 11;
  ASSERT(first??);
  ASSERT(second??);
  ASSERT(third??);
  ASSERT((PUN (slots->) AS BYTE) == 7);
  ASSERT((PUN slots[1] AS BYTE) == 9);
  ASSERT((PUN ((slots + 2)->) AS BYTE) == 11);
  ASSERT((slots[&1] - slots) == 1);
  DESTROY AT((slots + 2)->) BYTE;
  DESTROY AT(slots[1]) BYTE;
  DESTROY AT(slots->) BYTE;
  CONSTEXPR_DEALLOC_MULTIPLE#BYTE(slots, count);
  RETURN 27;
}

::constexpr_multialloc_test STATIC_TEST
{
  ASSERT(constexpr_multialloc_helper() == 27);
}

::constexpr_multialloc_zero_count_test STATIC_TEST
{
  VAR count SZ := 0;
  VAR slots =>> STORAGE(BYTE) := CONSTEXPR_ALLOC_MULTIPLE#BYTE(count);
  CONSTEXPR_DEALLOC_MULTIPLE#BYTE(slots, count);
}

::byte_storage_buffer CLASS
{
  .data VAR =>> STORAGE(BYTE);
  .count VAR SZ;
}

::constexpr_multialloc_container_test STATIC_TEST
{
  VAR buffer byte_storage_buffer;
  buffer.count := 2;
  buffer.data := CONSTEXPR_ALLOC_MULTIPLE#BYTE(buffer.count);
  PLACE AT(buffer.data->) BYTE := 4;
  PLACE AT((buffer.data + 1)->) BYTE := 8;
  ASSERT((PUN (buffer.data->) AS BYTE) == 4);
  ASSERT((PUN ((buffer.data + 1)->) AS BYTE) == 8);
  DESTROY AT((buffer.data + 1)->) BYTE;
  DESTROY AT(buffer.data->) BYTE;
  CONSTEXPR_DEALLOC_MULTIPLE#BYTE(buffer.data, buffer.count);
}

::constexpr_alloc_double_free_test STATIC_TEST EXPECT_FAIL
{
  VAR slot_ptr -> STORAGE(I32) := CONSTEXPR_ALLOC#I32();
  VAR copy_ptr -> STORAGE(I32) := slot_ptr;
  CONSTEXPR_DEALLOC#I32(slot_ptr);
  CONSTEXPR_DEALLOC#I32(copy_ptr);
}

::constexpr_multialloc_wrong_count_test STATIC_TEST EXPECT_FAIL
{
  VAR count SZ := 2;
  VAR slots =>> STORAGE(BYTE) := CONSTEXPR_ALLOC_MULTIPLE#BYTE(count);
  CONSTEXPR_DEALLOC_MULTIPLE#BYTE(slots, 3);
}

::constexpr_multialloc_interior_free_test STATIC_TEST EXPECT_FAIL
{
  VAR count SZ := 2;
  VAR slots =>> STORAGE(BYTE) := CONSTEXPR_ALLOC_MULTIPLE#BYTE(count);
  CONSTEXPR_DEALLOC_MULTIPLE#BYTE(slots + 1, count);
}

::constexpr_alloc_live_trivial_free_test STATIC_TEST EXPECT_FAIL
{
  VAR slot_ptr -> STORAGE(I32) := CONSTEXPR_ALLOC#I32();
  PLACE AT(slot_ptr->) I32 := 5;
  CONSTEXPR_DEALLOC#I32(slot_ptr);
}

::constexpr_alloc_live_nontrivial_free_test STATIC_TEST EXPECT_FAIL
{
  VAR slot_ptr -> STORAGE(buz) := CONSTEXPR_ALLOC#buz();
  PLACE AT(slot_ptr->) buz;
  CONSTEXPR_DEALLOC#buz(slot_ptr);
}

::constexpr_multialloc_live_trivial_free_test STATIC_TEST EXPECT_FAIL
{
  VAR count SZ := 1;
  VAR slots =>> STORAGE(BYTE) := CONSTEXPR_ALLOC_MULTIPLE#BYTE(count);
  PLACE AT(slots->) BYTE := 1;
  CONSTEXPR_DEALLOC_MULTIPLE#BYTE(slots, count);
}

::constexpr_alloc_use_after_free_pun_test STATIC_TEST EXPECT_FAIL
{
  VAR slot_ptr -> STORAGE(I32) := CONSTEXPR_ALLOC#I32();
  PLACE AT(slot_ptr->) I32 := 5;
  DESTROY AT(slot_ptr->) I32;
  VAR freed_ptr -> STORAGE(I32) := slot_ptr;
  CONSTEXPR_DEALLOC#I32(slot_ptr);
  ASSERT((PUN (freed_ptr->) AS I32) == 5);
}

::constexpr_alloc_use_after_free_place_test STATIC_TEST EXPECT_FAIL
{
  VAR slot_ptr -> STORAGE(I32) := CONSTEXPR_ALLOC#I32();
  VAR freed_ptr -> STORAGE(I32) := slot_ptr;
  CONSTEXPR_DEALLOC#I32(slot_ptr);
  PLACE AT(freed_ptr->) I32 := 7;
}

::constexpr_alloc_use_after_free_destroy_test STATIC_TEST EXPECT_FAIL
{
  VAR slot_ptr -> STORAGE(I32) := CONSTEXPR_ALLOC#I32();
  PLACE AT(slot_ptr->) I32 := 5;
  DESTROY AT(slot_ptr->) I32;
  VAR freed_ptr -> STORAGE(I32) := slot_ptr;
  CONSTEXPR_DEALLOC#I32(slot_ptr);
  DESTROY AT(freed_ptr->) I32;
}

::constexpr_alloc_use_after_free_load_store_test STATIC_TEST EXPECT_FAIL
{
  VAR slot_ptr -> STORAGE(I32) := CONSTEXPR_ALLOC#I32();
  VAR value_ptr ->I32 := PLACE AT(slot_ptr->) I32 := 5;
  DESTROY AT(slot_ptr->) I32;
  CONSTEXPR_DEALLOC#I32(slot_ptr);
  value_ptr-> := 9;
}

::constexpr_alloc_use_after_free_pointer_ops_test STATIC_TEST EXPECT_FAIL
{
  VAR count SZ := 2;
  VAR slots =>> STORAGE(BYTE) := CONSTEXPR_ALLOC_MULTIPLE#BYTE(count);
  VAR freed_slots =>> STORAGE(BYTE) := slots;
  CONSTEXPR_DEALLOC_MULTIPLE#BYTE(slots, count);
  freed_slots++;
}

::aligned_storage_buz_helper FUNCTION(): I32
{
  VAR slot ALIGNED_STORAGE(4, 4);
  VAR p ->buz := PLACE AT(slot) buz;
  ASSERT(p??);
  ASSERT(buz_x(PUN slot AS buz) == 9);
  DESTROY AT(slot) buz;
  RETURN 9;
}

::aligned_storage_baz FUNCTION()
{
      VAR slot ALIGNED_STORAGE(4, 4);
      VAR a -> ->I32 := PLACE AT(slot) ->I32;
}

::storage_wrong_type_baz FUNCTION()
{
      VAR slot STORAGE(buz);
      VAR a ->yak := PLACE AT(slot) yak;
}

::buz_x FUNCTION(%b CONST& buz): I32
{
  RETURN b.x;
}

::buz_inc FUNCTION(%b MUT& buz)
{
  b.foo();
}
