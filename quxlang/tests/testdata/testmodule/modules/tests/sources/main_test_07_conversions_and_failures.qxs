LANGUAGE QUXLANG EN 0.0;

::argument_passing_helper FUNCTION(@arg bam, @int & I32)
{
   int := int + arg.x;
}


::implicit_foo CLASS
{
    .x VAR I32;

    .CONSTRUCTOR FUNCTION(@OTHER I32)
    {
        .x := OTHER;
    }
}

::explicit_cast_only CLASS
{
    .x VAR I32;

    .CONSTRUCTOR FUNCTION(@EXPLICIT I32)
    {
        .x := EXPLICIT;
    }
}

::implicit_conversions_test STATIC_TEST
{
    VAR a implicit_foo;
    a := 5;

    ASSERT(a.x == 5);

    VAR b I32 := 8;
    a := b;

    ASSERT(a.x == 8);

    VAR c explicit_cast_only := b AS explicit_cast_only;
    ASSERT(c.x == 8);
}

::implicit_conversions_test_unit_test UNIT_TEST
{
    VAR a implicit_foo;
    a := 5;

    ASSERT(a.x == 5);

    VAR b I32 := 8;
    a := b;

    ASSERT(a.x == 8);

    VAR c explicit_cast_only := b AS explicit_cast_only;
    ASSERT(c.x == 8);
}




::yak CLASS
{
   .z VAR -> I32;
   .f VAR =>> I32;
   .f_count VAR SZ;

   .DESTRUCTOR FUNCTION()
   {
     IF (.z??)
     {
        .z-> := .z-> + 1;
     }

     IF (.f??)
     {
        WHILE(.f_count > 0)
        {
           .f-> ++;
           .f++;
           .f--;
           .f++;
           .f_count := .f_count - 1;
        }
     }
   }
}

::foobar FUNCTION(): U64
{
  VAR x U64;
  x := 1;
  RETURN x;
}

::pinc_helper FUNCTION() : I32
{
  VAR x [3 + foobar()]I32;
  x[0] := 0;
  x[1] := 0;
  x[2] := 0;
  x[3] := 0;
  VAR y =>> I32;
  y := x[& 0];
  y++;
  y++;
  y--;
  y-> ++ ;
  y-> ++ ;
  VAR three I32;
  three := 3;
  ASSERT (three == 3);
  RETURN x[1] ;
}

::basic_passing_static_test STATIC_TEST
{
  ASSERT (3 == 3);
}

::basic_passing_static_test_unit_test UNIT_TEST
{
  ASSERT (3 == 3);
}

::unresolved_symbol_compilation_failure_test STATIC_TEST EXPECT_COMPILATION_FAILURE
{
  missing_static_test_symbol();
}

::assertion_expect_fail_test STATIC_TEST EXPECT_FAIL
{
  ASSERT (3 == 4);
}

::narrowing_implicit_conversion_fails_test STATIC_TEST EXPECT_COMPILATION_FAILURE
{
  VAR x I32 := 300;
  VAR y I8 := x;
}

::narrowing_explicit_no_spec_fails_test STATIC_TEST EXPECT_COMPILATION_FAILURE
{
  VAR x I32 := 300;
  VAR y I8 := x AS I8;
}

::narrowing_explicit_partial_conversion_test STATIC_TEST
{
  VAR x I32 := 300;
  VAR y I8 := x AS PARTIAL I8;
  ASSERT(y == 44);
}

::narrowing_explicit_partial_conversion_test_unit_test UNIT_TEST
{
  VAR x I32 := 300;
  VAR y I8 := x AS PARTIAL I8;
  ASSERT(y == 44);
}

::widening_implicitly_okay_test STATIC_TEST
{
  VAR x I32 := 300;
  VAR y I64 := x;
  ASSERT(y == 300);
}

::widening_implicitly_okay_test_unit_test UNIT_TEST
{
  VAR x I32 := 300;
  VAR y I64 := x;
  ASSERT(y == 300);
}

::float_inexact_literal_requires_approximate_test STATIC_TEST EXPECT_FAIL
{
  VAR x F32 := 0.4;
}

::float_inexact_integer_requires_approximate_test STATIC_TEST EXPECT_COMPILATION_FAILURE
{
  VAR x I32 := 16777217;
  VAR y F32 := x;
}

::float_precision_bits_convertible_test STATIC_TEST
{
  VAR x1 I25;
  VAR x2 U24;

  VAR f F32;

  f := x1;
  f := x2;

  ASSERT(f == 0);
}

::float_precision_bits_convertible_test_unit_test UNIT_TEST
{
  VAR x1 I25;
  VAR x2 U24;

  VAR f F32;

  f := x1;
  f := x2;

  ASSERT(f == 0);
}

::float_precision_unsigned_not_convertible_test STATIC_TEST EXPECT_COMPILATION_FAILURE
{
  VAR x U25;
  VAR f F32;

  f := x;
  ASSERT(f == 0);
}

::float_precision_signed_not_convertible_test STATIC_TEST  EXPECT_COMPILATION_FAILURE
{
  VAR x I26;
  VAR f F32;

  f := x;
  ASSERT(f == 0);
}

::same_width_signed_to_unsigned_implicitly_fails_test STATIC_TEST EXPECT_COMPILATION_FAILURE
{
  VAR x I32 := 300;
  VAR y U32 := x;
}

::same_width_unsigned_to_signed_implicitly_fails_test STATIC_TEST EXPECT_COMPILATION_FAILURE
{
  VAR x U32 := 300;
  VAR y I32 := x;
}

::void_pointer_instance_reinterpret_roundtrip_test STATIC_TEST
{
  VAR x I32 := 11;
  VAR p ->I32 := x<-;
  VAR vp ->VOID := p AS REINTERPRET ->VOID;
  VAR back ->I32 := vp AS REINTERPRET ->I32;
  back-> := back-> + 6;
  ASSERT(x == 17);
}

::void_pointer_instance_reinterpret_roundtrip_test_unit_test UNIT_TEST
{
  VAR x I32 := 11;
  VAR p ->I32 := x<-;
  VAR vp ->VOID := p AS REINTERPRET ->VOID;
  VAR back ->I32 := vp AS REINTERPRET ->I32;
  back-> := back-> + 6;
  ASSERT(x == 17);
}

::void_pointer_array_reinterpret_roundtrip_test STATIC_TEST
{
  VAR values [2]I32;
  values[0] := 7;
  values[1] := 13;
  VAR p =>>I32 := values[&0];
  VAR vp =>>VOID := p AS REINTERPRET =>>VOID;
  VAR back =>>I32 := vp AS REINTERPRET =>>I32;
  ASSERT(back-> == 7);
  back := back + 1;
  ASSERT(back-> == 13);
}

::void_pointer_array_reinterpret_roundtrip_test_unit_test UNIT_TEST
{
  VAR values [2]I32;
  values[0] := 7;
  values[1] := 13;
  VAR p =>>I32 := values[&0];
  VAR vp =>>VOID := p AS REINTERPRET =>>VOID;
  VAR back =>>I32 := vp AS REINTERPRET =>>I32;
  ASSERT(back-> == 7);
  back := back + 1;
  ASSERT(back-> == 13);
}

::void_pointer_const_reinterpret_roundtrip_test STATIC_TEST
{
  VAR x I32 := 11;
  VAR p CONST->I32 := x<-;
  VAR vp CONST->VOID := p AS REINTERPRET CONST->VOID;
  VAR back CONST->I32 := vp AS REINTERPRET CONST->I32;
  ASSERT(back-> == 11);
}

::void_pointer_const_reinterpret_roundtrip_test_unit_test UNIT_TEST
{
  VAR x I32 := 11;
  VAR p CONST->I32 := x<-;
  VAR vp CONST->VOID := p AS REINTERPRET CONST->VOID;
  VAR back CONST->I32 := vp AS REINTERPRET CONST->I32;
  ASSERT(back-> == 11);
}

::void_pointer_reinterpret_preserves_const_test STATIC_TEST EXPECT_COMPILATION_FAILURE
{
  VAR x I32 := 11;
  VAR p CONST->I32 := x<-;
  VAR vp CONST->VOID := p AS REINTERPRET CONST->VOID;
  VAR back ->I32 := vp AS REINTERPRET ->I32;
}

::null_void_pointer_reinterpret_backcast_test STATIC_TEST
{
  VAR vp ->VOID;
  VAR back ->I32 := vp AS REINTERPRET ->I32;
  ASSERT((back??) == FALSE);
}

::null_void_pointer_reinterpret_backcast_test_unit_test UNIT_TEST
{
  VAR vp ->VOID;
  VAR back ->I32 := vp AS REINTERPRET ->I32;
  ASSERT((back??) == FALSE);
}

::void_pointer_cast_requires_reinterpret_test STATIC_TEST EXPECT_COMPILATION_FAILURE
{
  VAR x I32 := 1;
  VAR p ->I32 := x<-;
  VAR vp ->VOID := p AS ->VOID;
}

::void_pointer_backcast_requires_reinterpret_test STATIC_TEST EXPECT_COMPILATION_FAILURE
{
  VAR vp ->VOID;
  VAR p ->I32 := vp AS ->I32;
}

::direct_reinterpret_between_concrete_pointers_fails_test STATIC_TEST EXPECT_COMPILATION_FAILURE
{
  VAR x I32 := 1;
  VAR p ->I32 := x<-;
  VAR bad ->BYTE := p AS REINTERPRET ->BYTE;
}

::void_instance_pointer_dereference_fails_test STATIC_TEST EXPECT_COMPILATION_FAILURE
{
  VAR vp ->VOID;
  vp->;
}

::void_array_pointer_index_fails_test STATIC_TEST EXPECT_COMPILATION_FAILURE
{
  VAR vp =>>VOID;
  vp[0];
}

::void_array_pointer_add_fails_test STATIC_TEST EXPECT_COMPILATION_FAILURE
{
  VAR vp =>>VOID;
  vp + 1;
}

::void_array_pointer_subtract_fails_test STATIC_TEST EXPECT_COMPILATION_FAILURE
{
  VAR vp =>>VOID;
  vp - 1;
}

::void_array_pointer_increment_fails_test STATIC_TEST EXPECT_COMPILATION_FAILURE
{
  VAR vp =>>VOID;
  vp++;
}

::void_array_pointer_decrement_fails_test STATIC_TEST EXPECT_COMPILATION_FAILURE
{
  VAR vp =>>VOID;
  vp--;
}

::void_pointer_wrong_instance_backcast_fails_test STATIC_TEST EXPECT_FAIL
{
  VAR x I32 := 1;
  VAR p ->I32 := x<-;
  VAR vp ->VOID := p AS REINTERPRET ->VOID;
  VAR bad ->BYTE := vp AS REINTERPRET ->BYTE;
  ASSERT(bad??);
}

::void_pointer_wrong_array_backcast_fails_test STATIC_TEST EXPECT_FAIL
{
  VAR values [1]I32;
  VAR p =>>I32 := values[&0];
  VAR vp =>>VOID := p AS REINTERPRET =>>VOID;
  VAR bad =>>BYTE := vp AS REINTERPRET =>>BYTE;
  ASSERT(bad??);
}

::linux_write_syscall INCLUDE_IF(OS_LINUX && ARCH_X64) ASM_PROCEDURE X64
  CALLABLE CALLCONV CCALL(I32, CONST=>> BYTE, SZ; RETURN SZ)
{
  MOV RAX, 1
  SYSCALL
  RET
}

::linux_write_syscall INCLUDE_IF(OS_LINUX && ARCH_X86) ASM_PROCEDURE X64
  CALLABLE CALLCONV CCALL(I32, CONST=>> BYTE, SZ; RETURN SZ)
{
  MOV EBX, [ESP+4]
  MOV ECX, [ESP+8]
  MOV EDX, [ESP+12]
  MOV EAX, 4
  INT 0x80
  RET
}

::linux_write_syscall INCLUDE_IF(OS_LINUX && ARCH_ARM64) ASM_PROCEDURE ARM
  CALLABLE CALLCONV CCALL(I32, CONST=>> BYTE, SZ; RETURN SZ)
{
  MOV X8, 64
  SVC 0
  RET
}

::hello_world_message STATIC STRING_CONSTANT := "hello world!";

::write_hello_world_linux INCLUDE_IF(OS_LINUX) FUNCTION()
{
  VAR begin CONST=>> BYTE := hello_world_message.BEGIN();
  VAR count SZ := (hello_world_message.END() - begin) AS ASSUME SZ;
  linux_write_syscall(1, begin, count);
}

::main FUNCTION(): I32
{
  write_hello_world_linux();
  RETURN 0;
}
